    * { box-sizing: border-box; }
    body {
      font-family: var(--vscode-font-family);
      color: var(--fg);
      background: {{{background}}};
      margin: 0;
      padding: {{padding}};
      height: 100vh;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      gap: {{gap}};
    }
