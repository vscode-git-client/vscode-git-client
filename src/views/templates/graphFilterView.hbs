{{> partials/documentStart title=title}}
    {{> partials/styles/theme}}
    {{> partials/styles/contextMenu minWidth="260px"}}
    {{> partials/styles/bodyBase background="var(--bg)" padding="14px 16px" gap="10px"}}
    {{> partials/styles/viewHeading titleSize="14px"}}
    form {
      display: flex;
      flex-direction: column;
      gap: 10px;
      min-height: 0;
      flex: 1;
    }
    .filters-inline {
      display: grid;
      gap: 8px;
      grid-template-columns: minmax(160px, 1fr) minmax(160px, 1fr) minmax(160px, 1fr) minmax(132px, 160px) minmax(132px, 160px);
      align-items: end;
      --filter-label-weight: 600;
      --filter-input-border: var(--vscode-input-border, var(--border));
      --filter-input-background: var(--vscode-input-background);
      --filter-input-color: var(--vscode-input-foreground);
      --filter-input-padding: 7px 8px;
      --filter-input-font-family: var(--vscode-font-family);
    }
    {{> partials/styles/filterFieldAtoms}}
    {{> partials/styles/fieldClear}}
    {{> partials/styles/autocomplete listClass="autocomplete-list" optionClass="autocomplete-option" shadowAlpha="0.25"}}
    .filter-tags-row {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      min-height: 0;
      padding: 0;
      margin-bottom: 2px;
    }
    .filter-tags-row:empty {
      display: none;
    }
    .filter-tag {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      background: var(--vscode-badge-background, var(--accent));
      color: var(--vscode-badge-foreground, #fff);
      font-size: 11px;
      font-family: var(--vscode-font-family);
      border-radius: 4px;
      padding: 1px 6px;
      line-height: 1.5;
      white-space: nowrap;
      max-width: 220px;
      overflow: hidden;
      text-overflow: ellipsis;
      user-select: none;
      cursor: default;
    }
    .filter-tag[data-kind="branch"] {
      background: var(--vscode-badge-background, #007acc);
    }
    .filter-tag[data-kind="author"] {
      background: var(--vscode-charts-green, #388a34);
    }
    .filter-tag .tag-remove {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      border: none;
      background: transparent;
      color: inherit;
      font-size: 12px;
      cursor: pointer;
      padding: 0;
      margin-left: 1px;
      opacity: 0.7;
      line-height: 1;
      flex-shrink: 0;
    }
    .filter-tag .tag-remove:hover {
      opacity: 1;
      background: rgba(255,255,255,0.2);
    }
    .actions {
      display: flex;
      gap: 8px;
      justify-content: flex-end;
      align-items: center;
      border-top: 1px solid var(--border);
      padding-top: 8px;
    }
    .actions button {
      padding: 6px 12px;
      font-size: 12px;
      border-radius: 4px;
      cursor: pointer;
      font-family: inherit;
    }
    .actions button.primary {
      background: var(--vscode-button-background);
      color: var(--vscode-button-foreground);
      border: 1px solid var(--vscode-button-background);
    }
    .actions button.primary:hover {
      background: var(--vscode-button-hoverBackground);
    }
    {{> partials/styles/outlineButton
      selector=".actions button.secondary"
      padding="6px 12px"
      radius="4px"
      fontSize="12px"
      color="var(--vscode-button-secondaryForeground, var(--fg))"
      background="var(--vscode-button-secondaryBackground, transparent)"
      hoverBorderColor="var(--accent)"
    }}
    .commit-preview {
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      min-height: 0;
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .preview-header {
      font-size: 11px;
      color: var(--muted);
      padding: 6px 8px;
      border-bottom: 1px solid var(--border);
    }
    {{> partials/styles/flexScrollArea className="preview-table-wrap" overflow="auto"}}
    {{> partials/styles/tableBase cellPadding="6px 4px"}}
    {{> partials/styles/commitListBase}}
  </style>
</head>
<body>
  <header style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px;">
    <div>
      {{> partials/molecules/viewHeading title=title hint=hint}}
    </div>
    {{#unless showApply}}
      <div class="actions" style="border-top: none; padding-top: 0; margin-top: 0;">
        <button type="button" class="secondary" id="cancel">Close</button>
        <button type="button" class="secondary" id="clear">Clear Filters</button>
      </div>
    {{/unless}}
  </header>

  <div class="filter-tags-row" id="filter-tags-row"></div>

  <form id="form">
    <section class="filters-inline">
      {{> partials/molecules/textFilterField
        id="message"
        name="message"
        label="Message"
        note="(subject/id)"
        placeholder="fix login, HOTFIX-123, short SHA"
        clearLabel="message"
        autofocus=true
        spellcheck="false"
      }}
      {{> partials/molecules/textFilterField
        id="branch"
        name="branch"
        label="Branch"
        placeholder="main, feature/login"
        clearLabel="branch"
        autocompleteAttr="off"
        spellcheck="false"
        autocompleteId="branch-list"
        autocompleteClass="autocomplete-list"
        autocompleteLabel="Branch suggestions"
      }}
      {{> partials/molecules/textFilterField
        id="author"
        name="author"
        label="Author"
        placeholder="name or email"
        clearLabel="author"
        autocompleteAttr="off"
        spellcheck="false"
        autocompleteId="author-list"
        autocompleteClass="autocomplete-list"
        autocompleteLabel="Author suggestions"
      }}
      {{> partials/molecules/dateFilterField
        id="since"
        name="since"
        label="Since"
        clearLabel="since"
      }}
      {{> partials/molecules/dateFilterField
        id="until"
        name="until"
        label="Until"
        clearLabel="until"
      }}
    </section>

    <section class="commit-preview">
      <div class="preview-header" id="preview-header">Matching commits: 0</div>
      <div class="preview-table-wrap">
        {{> partials/commitTable tbodyId="preview-body"}}
        <div id="load-more-sentinel" style="height:1px"></div>
      </div>
    </section>

  </form>

  {{> partials/graphContextMenu}}

  <div id="refresh-context-menu" class="context-menu" role="menu" aria-label="Refresh context menu" style="min-width:120px">
    <button class="menu-item" data-action="refresh">Refresh</button>
  </div>

  <script>
    const vscode = acquireVsCodeApi();
    const form = document.getElementById('form');
    const SHOW_APPLY = {{#if showApply}}true{{else}}false{{/if}};
    const state = {
      branches: [],
      authors: [],
      allAuthors: [],
      commits: [],
      loading: false,
      hasMore: false,
      loadMoreErrored: false,
      streaming: false,
      streamingSeen: false,
      virtThreshold: 200,
      selectedBranches: [],
      selectedAuthors: []
    };
    const messageInput = document.getElementById('message');
    const branchInput = document.getElementById('branch');
    const authorInput = document.getElementById('author');
    const filterTagsRow = document.getElementById('filter-tags-row');
    const sinceInput = document.getElementById('since');
    const untilInput = document.getElementById('until');
    const previewHeader = document.getElementById('preview-header');
    const previewBody = document.getElementById('preview-body');
    const cancelButton = document.getElementById('cancel');
    const clearButton = document.getElementById('clear');
    const fieldClearButtons = Array.from(document.querySelectorAll('.field-clear'));
    let applyDebounceTimer = null;
    let loadMoreObserver = null;
    let inputRevision = 0;

    {{> partials/scripts/commitContextMenu}}

    const refreshContextMenu = (() => {
      const menu = document.getElementById('refresh-context-menu');
      if (!menu) { return { close() {}, open() {} }; }
      const close = () => menu.classList.remove('visible');
      const open = (x, y) => {
        menu.style.left = '0px';
        menu.style.top = '0px';
        menu.classList.add('visible');
        const menuRect = menu.getBoundingClientRect();
        const viewport = window.visualViewport;
        const viewportLeft = viewport ? viewport.offsetLeft : 0;
        const viewportTop = viewport ? viewport.offsetTop : 0;
        const viewportWidth = viewport ? viewport.width : window.innerWidth;
        const viewportHeight = viewport ? viewport.height : window.innerHeight;
        const minX = viewportLeft + 8;
        const minY = viewportTop + 8;
        const maxX = Math.max(minX, viewportLeft + viewportWidth - menuRect.width - 8);
        const maxY = Math.max(minY, viewportTop + viewportHeight - menuRect.height - 8);
        menu.style.left = Math.max(minX, Math.min(x, maxX)) + 'px';
        menu.style.top = Math.max(minY, Math.min(y, maxY)) + 'px';
      };
      menu.addEventListener('click', (event) => {
        const target = event.target && event.target.closest ? event.target.closest('.menu-item[data-action]') : null;
        if (!target || target.disabled) { return; }
        const action = target.getAttribute('data-action');
        if (action === 'refresh') {
          cancelPendingApply();
          vscode.postMessage({ type: 'apply', filters: collect(), inputRevision });
          close();
        }
      });
      window.addEventListener('blur', close);
      window.addEventListener('scroll', close, true);
      return { close, open };
    })();

    let selectionAnchorSha = null;

    const getVisibleCommitRows = () =>
      Array.from(document.querySelectorAll('.commit-row')).filter((row) => row.style.display !== 'none');
    const getCommitSha = (row) => (row && row.getAttribute ? row.getAttribute('data-sha') || '' : '');
    const isCommitRowSelected = (row) => Boolean(row && row.classList && row.classList.contains('selected'));
    const setCommitRowSelected = (row, selected) => {
      if (!row || !row.classList) { return; }
      row.classList.toggle('selected', selected);
      row.setAttribute('aria-selected', selected ? 'true' : 'false');
    };
    const clearCommitSelection = () => {
      Array.from(document.querySelectorAll('.commit-row.selected')).forEach((row) => setCommitRowSelected(row, false));
    };
    const getSelectedCommitRows = () =>
      Array.from(document.querySelectorAll('.commit-row.selected')).filter((row) => row.style.display !== 'none');
    const getSelectedCommitShas = () =>
      Array.from(new Set(getSelectedCommitRows().map((row) => getCommitSha(row)).filter(Boolean)));

    const selectRange = (targetRow, additive) => {
      const visibleRows = getVisibleCommitRows();
      const targetSha = getCommitSha(targetRow);
      const anchorIndex = visibleRows.findIndex((row) => getCommitSha(row) === selectionAnchorSha);
      const targetIndex = visibleRows.findIndex((row) => getCommitSha(row) === targetSha);
      if (targetIndex < 0) {
        return;
      }
      if (anchorIndex < 0) {
        if (!additive) {
          clearCommitSelection();
        }
        setCommitRowSelected(targetRow, true);
        selectionAnchorSha = targetSha || selectionAnchorSha;
        return;
      }
      const from = Math.min(anchorIndex, targetIndex);
      const to = Math.max(anchorIndex, targetIndex);
      if (!additive) {
        clearCommitSelection();
      }
      for (let index = from; index <= to; index += 1) {
        setCommitRowSelected(visibleRows[index], true);
      }
    };

    const isContinuousSelection = () => {
      const selected = getSelectedCommitRows();
      if (selected.length < 2) return true;
      const visible = getVisibleCommitRows();
      const indices = selected.map(row => visible.indexOf(row)).filter(idx => idx !== -1).sort((a, b) => a - b);
      if (indices.length !== selected.length) return false;
      return indices[indices.length - 1] - indices[0] === indices.length - 1;
    };

    const dispatchSelectionChange = () => {
      const count = getSelectedCommitRows().length;
      vscode.postMessage({ type: 'selectionChange', count, isContinuous: isContinuousSelection() });
    };

    const updateSelection = (row, event, options = {}) => {
      if (!row) {
        return;
      }
      const forContextMenu = Boolean(options.forContextMenu);
      const toggle = Boolean(event && (event.ctrlKey || event.metaKey));
      const range = Boolean(event && event.shiftKey);
      const sha = getCommitSha(row);

      if (range) {
        selectRange(row, toggle);
        if (sha) {
          selectionAnchorSha = sha;
        }
        dispatchSelectionChange();
        return;
      }

      if (toggle) {
        setCommitRowSelected(row, !isCommitRowSelected(row));
        if (sha) {
          selectionAnchorSha = sha;
        }
        dispatchSelectionChange();
        return;
      }

      if (forContextMenu && isCommitRowSelected(row)) {
        if (sha) {
          selectionAnchorSha = sha;
        }
        dispatchSelectionChange();
        return;
      }

      clearCommitSelection();
      setCommitRowSelected(row, true);
      if (sha) {
        selectionAnchorSha = sha;
      }
      dispatchSelectionChange();
    };

    window.addEventListener('message', (event) => {
      const msg = event.data;
      if (msg && msg.type === 'loading') {
        state.loading = Boolean(msg.loading);
        renderPreview();
        return;
      }
      if (msg && msg.type === 'init') {
        const responseInputRevision = Number(msg.inputRevision);
        if (Number.isFinite(responseInputRevision) && responseInputRevision < inputRevision) {
          return;
        }
        if (loadMoreObserver) { loadMoreObserver.disconnect(); loadMoreObserver = null; }
        state.loading = false;
        state.loadMoreErrored = false;
        state.hasMore = Boolean(msg.hasMore);
        state.streaming = false;
        state.streamingSeen = false;
        if (typeof msg.virtThreshold === 'number' && msg.virtThreshold >= 0) {
          state.virtThreshold = msg.virtThreshold;
        }
        const f = msg.filters || {};
        messageInput.value = f.message || '';
        const branchValues = Array.isArray(f.branch) ? f.branch : (f.branch ? [f.branch] : []);
        const authorValues = Array.isArray(f.author) ? f.author : (f.author ? [f.author] : []);
        state.selectedBranches = branchValues;
        state.selectedAuthors = authorValues;
        renderTags();
        branchInput.value = '';
        authorInput.value = '';
        sinceInput.value = f.since || '';
        untilInput.value = f.until || '';
        state.branches = Array.isArray(msg.branches) ? msg.branches : [];
        state.commits = Array.isArray(msg.commits) ? msg.commits : [];
        state.authors = Array.from(
          new Set(state.commits.map((c) => (typeof c.author === 'string' ? c.author.trim() : '')).filter(Boolean))
        ).sort((a, b) => a.localeCompare(b));
        state.allAuthors = Array.from(new Set([...state.allAuthors, ...state.authors])).sort((a, b) => a.localeCompare(b));
        branchAutocomplete.setSource(state.branches);
        authorAutocomplete.setSource(state.allAuthors);
        renderPreview();
        if (state.hasMore) { attachLoadMoreObserver(); }
        return;
      }
      if (msg && msg.type === 'appendCommits') {
        state.loading = false;
        state.loadMoreErrored = false;
        state.hasMore = Boolean(msg.hasMore);
        if (typeof msg.streaming === 'boolean') {
          state.streaming = msg.streaming;
          if (msg.streaming) {
            state.streamingSeen = true;
          }
        }
        const newCommits = Array.isArray(msg.commits) ? msg.commits : [];
        state.commits = state.commits.concat(newCommits);
        const newAuthors = newCommits
          .map((c) => (typeof c.author === 'string' ? c.author.trim() : ''))
          .filter(Boolean);
        if (newAuthors.length > 0) {
          state.authors = Array.from(new Set([...state.authors, ...newAuthors])).sort((a, b) => a.localeCompare(b));
          state.allAuthors = Array.from(new Set([...state.allAuthors, ...newAuthors])).sort((a, b) => a.localeCompare(b));
          authorAutocomplete.setSource(state.allAuthors);
        }
        appendRows(newCommits);
        return;
      }
      if (msg && msg.type === 'loadMoreError') {
        state.loading = false;
        state.loadMoreErrored = true;
        previewHeader.textContent = previewHeader.textContent + ' — error loading more (re-apply filters to retry)';
        return;
      }
    });

    function escapeHtml(value) {
      return String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    }

    function parseSince(value) {
      if (!value) { return undefined; }
      const timestamp = new Date(value + 'T00:00:00').getTime();
      return Number.isFinite(timestamp) ? timestamp : undefined;
    }

    function parseUntil(value) {
      if (!value) { return undefined; }
      const timestamp = new Date(value + 'T23:59:59.999').getTime();
      return Number.isFinite(timestamp) ? timestamp : undefined;
    }

    function renderGraphGlyph(graph) {
      if (graph === '<') { return '◀'; }
      if (graph === '>') { return '▶'; }
      if (graph === '-') { return '●'; }
      return '○';
    }

    function buildRow(commit) {
      const sha = escapeHtml(commit.sha || '');
      const subject = escapeHtml(commit.subject || '');
      const author = escapeHtml(commit.author || '');
      const timestamp = Number(commit.dateTimestamp || 0);
      const full = escapeHtml(commit.dateTitle || '');
      const dateText = escapeHtml(commit.dateLabel || '');
      const graph = escapeHtml(renderGraphGlyph(commit.graph));
      return '<tr class="commit-row" data-sha="' + sha + '" data-subject="' + subject + '" data-author="' + author + '" data-timestamp="' + timestamp + '" data-side="filter" title="' + sha + '"><td class="col-graph copyable" title="Copy commit hash: ' + sha + '">' + graph + '</td><td class="col-subject" title="' + subject + '">' + subject + '</td><td class="col-author" title="' + author + '">' + author + '</td><td class="col-date muted"><span title="' + full + '">' + dateText + '</span></td></tr>';
    }

    function scoreMatch(candidate, keyword) {
      if (!keyword) { return 3; }
      const i = candidate.indexOf(keyword);
      if (i < 0) { return Number.POSITIVE_INFINITY; }
      if (i === 0) { return 0; }
      if (candidate[i - 1] === ' ' || candidate[i - 1] === '/' || candidate[i - 1] === '-') { return 1; }
      return 2;
    }

    function collect() {
      return {
        message: messageInput.value,
        branch: state.selectedBranches.length > 0 ? state.selectedBranches.slice() : undefined,
        author: state.selectedAuthors.length > 0 ? state.selectedAuthors.slice() : undefined,
        since: sinceInput.value,
        until: untilInput.value
      };
    }

    function scheduleApplyFilters() {
      if (!SHOW_APPLY) {
        return;
      }
      if (applyDebounceTimer !== null) {
        clearTimeout(applyDebounceTimer);
      }
      applyDebounceTimer = setTimeout(() => {
        applyDebounceTimer = null;
        vscode.postMessage({ type: 'apply', filters: collect(), inputRevision });
      }, 300);
    }

    function cancelPendingApply() {
      if (applyDebounceTimer !== null) {
        clearTimeout(applyDebounceTimer);
        applyDebounceTimer = null;
      }
    }

    function clearFilterInputs() {
      messageInput.value = '';
      branchInput.value = '';
      state.selectedBranches = [];
      authorInput.value = '';
      state.selectedAuthors = [];
      renderTags();
      sinceInput.value = '';
      untilInput.value = '';
      branchAutocomplete.close();
      authorAutocomplete.close();
      inputRevision += 1;
    }

    function noteFilterInputChanged() {
      inputRevision += 1;
      renderPreview();
      scheduleApplyFilters();
    }

    function noteFilterTextChanged() {
      inputRevision += 1;
      renderPreview();
    }

    function buildMatchPredicate(f) {
      const message = (f.message || '').trim().toLowerCase();
      const authorValues = Array.isArray(f.author) ? f.author : (f.author ? [f.author] : []);
      const authorFilters = authorValues.map(function (a) { return String(a || '').trim().toLowerCase(); }).filter(Boolean);
      const since = parseSince(f.since || '');
      const until = parseUntil(f.until || '');
      return function matchesFilter(commit) {
        const subject = String(commit.subject || '').toLowerCase();
        const sha = String(commit.sha || '').toLowerCase();
        const authorLower = String(commit.author || '').toLowerCase();
        const commitDate = Number(commit.dateTimestamp || 0);
        const messageOk = !message || subject.includes(message) || sha.includes(message);
        const authorOk = authorFilters.length === 0 || authorFilters.some(function (a) { return authorLower.includes(a); });
        const sinceOk = since === undefined || (Number.isFinite(commitDate) && commitDate >= since);
        const untilOk = until === undefined || (Number.isFinite(commitDate) && commitDate <= until);
        return messageOk && authorOk && sinceOk && untilOk;
      };
    }

    function getFilteredCommits() {
      return state.commits.filter(buildMatchPredicate(collect()));
    }

    function updatePreviewHeader() {
      const filtered = getFilteredCommits();
      if (state.streaming) {
        previewHeader.textContent = 'Loading commits... ' + filtered.length + ' loaded so far';
        return;
      }
      let label = 'Matching commits: ' + filtered.length;
      if (state.hasMore) {
        label += ' (scroll to load more)';
      } else if (state.streamingSeen) {
        label += ' (all loaded)';
      }
      previewHeader.textContent = label;
    }

    // --- Hybrid virtualization ---------------------------------------------
    // When the filtered commit list exceeds state.virtThreshold (default 200,
    // configurable via vscodeGitClient.commitListVirtualizationThreshold),
    // only the rows in (and near) the viewport are mounted in the DOM. Top
    // and bottom spacer rows occupy the remaining vertical space so the
    // scrollbar reflects the true list size. Below the threshold the existing
    // full-render path is used unchanged.
    //
    // Limitation: row-level selection state (`.selected`) lives in the DOM,
    // so rows scrolled out of the virtual window lose their selection. Most
    // commit actions operate on the row under the cursor or recent clicks,
    // which stay mounted; cross-window range selection is not supported.
    const tableWrap = document.querySelector('.preview-table-wrap');
    const VIRT_BUFFER_ROWS = 8;
    const FALLBACK_ROW_HEIGHT = 24;
    let virtRowHeight = 0;
    let virtScrollListener = null;
    let virtRafPending = false;

    function isVirtualizationEnabled(filtered) {
      const threshold = state.virtThreshold;
      return threshold > 0 && filtered.length > threshold;
    }

    function measureRowHeight() {
      if (virtRowHeight > 0) { return virtRowHeight; }
      const probe = document.createElement('tr');
      probe.className = 'commit-row';
      probe.style.visibility = 'hidden';
      probe.innerHTML = '<td class="col-graph">●</td><td class="col-subject">probe</td><td class="col-author">probe</td><td class="col-date"><span>probe</span></td>';
      previewBody.appendChild(probe);
      const rect = probe.getBoundingClientRect();
      virtRowHeight = rect.height > 0 ? rect.height : FALLBACK_ROW_HEIGHT;
      previewBody.removeChild(probe);
      return virtRowHeight;
    }

    function renderVirtual(filtered) {
      if (!tableWrap) {
        previewBody.innerHTML = filtered.map(buildRow).join('');
        return;
      }
      const rh = measureRowHeight();
      const viewportHeight = tableWrap.clientHeight || rh * 20;
      const scrollTop = tableWrap.scrollTop;
      const visibleCount = Math.ceil(viewportHeight / rh) + VIRT_BUFFER_ROWS * 2;
      const startIndex = Math.max(0, Math.floor(scrollTop / rh) - VIRT_BUFFER_ROWS);
      const endIndex = Math.min(filtered.length, startIndex + visibleCount);
      const topPad = startIndex * rh;
      const bottomPad = Math.max(0, (filtered.length - endIndex) * rh);

      const slice = filtered.slice(startIndex, endIndex);
      const parts = [];
      if (topPad > 0) {
        parts.push('<tr class="virt-spacer" aria-hidden="true"><td colspan="4" style="padding:0;border:0;height:' + topPad + 'px"></td></tr>');
      }
      parts.push(slice.map(buildRow).join(''));
      if (bottomPad > 0) {
        parts.push('<tr class="virt-spacer" aria-hidden="true"><td colspan="4" style="padding:0;border:0;height:' + bottomPad + 'px"></td></tr>');
      }
      previewBody.innerHTML = parts.join('');
    }

    function attachVirtScrollListener() {
      if (virtScrollListener || !tableWrap) { return; }
      virtScrollListener = () => {
        if (virtRafPending) { return; }
        virtRafPending = true;
        const raf = typeof window.requestAnimationFrame === 'function'
          ? window.requestAnimationFrame.bind(window)
          : (cb) => setTimeout(cb, 16);
        raf(() => {
          virtRafPending = false;
          const filtered = getFilteredCommits();
          if (isVirtualizationEnabled(filtered)) {
            renderVirtual(filtered);
          }
        });
      };
      tableWrap.addEventListener('scroll', virtScrollListener, { passive: true });
    }

    function detachVirtScrollListener() {
      if (!virtScrollListener || !tableWrap) { return; }
      tableWrap.removeEventListener('scroll', virtScrollListener);
      virtScrollListener = null;
    }

    function renderPreview() {
      if (state.loading) {
        previewHeader.textContent = 'Loading commits...';
        previewBody.innerHTML = '<tr><td colspan="4">Loading commits...</td></tr>';
        detachVirtScrollListener();
        return;
      }
      const filtered = getFilteredCommits();
      updatePreviewHeader();
      if (filtered.length === 0) {
        previewBody.innerHTML = '<tr><td colspan="4">No commits match current filters</td></tr>';
        detachVirtScrollListener();
        return;
      }
      if (isVirtualizationEnabled(filtered)) {
        renderVirtual(filtered);
        attachVirtScrollListener();
        return;
      }
      detachVirtScrollListener();
      previewBody.innerHTML = filtered.map(buildRow).join('');
    }

    function renderEmptyStateIfNeeded() {
      if (!previewBody.querySelector('.commit-row')) {
        previewBody.innerHTML = '<tr><td colspan="4">No commits match current filters</td></tr>';
      }
    }

    function appendRows(newCommits) {
      const filtered = getFilteredCommits();

      // Switch into (or stay in) virtualization mode once the filtered list
      // crosses the threshold — incremental DOM appends would defeat
      // virtualization, so re-render the visible window from scratch.
      if (isVirtualizationEnabled(filtered)) {
        renderVirtual(filtered);
        attachVirtScrollListener();
        updatePreviewHeader();
        return;
      }

      detachVirtScrollListener();

      const matchingRows = newCommits.filter(buildMatchPredicate(collect())).map(buildRow);

      if (matchingRows.length > 0 && previewBody.querySelector('td[colspan]')) {
        previewBody.innerHTML = '';
      }

      if (matchingRows.length > 0) {
        previewBody.insertAdjacentHTML('beforeend', matchingRows.join(''));
      } else {
        renderEmptyStateIfNeeded();
      }

      updatePreviewHeader();
    }

    document.addEventListener('click', (event) => {
      if (commitContextMenu.isVisible()) {
        if (!commitContextMenu.contains(event.target)) { commitContextMenu.close(); }
        return;
      }
      const refreshMenu = document.getElementById('refresh-context-menu');
      if (refreshMenu && refreshMenu.classList.contains('visible') && !refreshMenu.contains(event.target)) {
        refreshContextMenu.close();
        return;
      }
      const row = event.target && event.target.closest ? event.target.closest('.commit-row') : null;
      if (!row) { return; }
      const sha = row.getAttribute('data-sha') || '';
      if (!sha) { return; }
      const hasMultiModifier = event.shiftKey || event.ctrlKey || event.metaKey;
      updateSelection(row, event);
      if (hasMultiModifier) {
        const selectedShas = getSelectedCommitShas();
        if (selectedShas.length > 1) {
          vscode.postMessage({ type: 'openCommitRangeDetails', shas: selectedShas });
        }
        return;
      }
      const graphCell = event.target && event.target.closest ? event.target.closest('.col-graph.copyable') : null;
      if (graphCell) {
        event.stopPropagation();
        vscode.postMessage({ type: 'commitAction', action: 'copyRevisionNumber', sha });
        return;
      }
      const subject = row.getAttribute('data-subject') || '';
      vscode.postMessage({ type: 'openCommitDetails', sha, subject });
    });

    document.addEventListener('contextmenu', (event) => {
      const row = event.target && event.target.closest ? event.target.closest('.commit-row') : null;
      if (!row) {
        commitContextMenu.close();
        refreshContextMenu.close();
        // Let interactive elements keep their native context menu (inputs, textareas, etc.)
        const tag = (event.target && event.target.tagName) ? event.target.tagName.toLowerCase() : '';
        const isInteractive = tag === 'input' || tag === 'textarea' || tag === 'select' || tag === 'button' || (event.target && event.target.isContentEditable);
        if (isInteractive) { return; }
        event.preventDefault();
        refreshContextMenu.open(event.clientX, event.clientY);
        return;
      }
      refreshContextMenu.close();
      updateSelection(row, event, { forContextMenu: true });
      row._vscodeGitClientSelectedShas = getSelectedCommitShas();
      row._vscodeGitClientSelectedSubjects = getSelectedCommitRows()
        .map((item) => (item.getAttribute('data-subject') || '').trim())
        .filter(Boolean);
      commitContextMenu.openForRow(event, row);
    });

    function renderTags() {
      if (!filterTagsRow) { return; }
      filterTagsRow.innerHTML = '';
      var allTags = [];
      for (var i = 0; i < state.selectedBranches.length; i++) {
        allTags.push({ kind: 'branch', value: state.selectedBranches[i], index: i });
      }
      for (var j = 0; j < state.selectedAuthors.length; j++) {
        allTags.push({ kind: 'author', value: state.selectedAuthors[j], index: j });
      }
      for (var k = 0; k < allTags.length; k++) {
        var item = allTags[k];
        var tag = document.createElement('span');
        tag.className = 'filter-tag';
        tag.setAttribute('data-kind', item.kind);
        tag.setAttribute('data-index', String(item.index));
        tag.textContent = item.value;
        var removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'tag-remove';
        removeBtn.textContent = '×';
        removeBtn.setAttribute('aria-label', 'Remove ' + item.value);
        (function (kind, index) {
          removeBtn.addEventListener('mousedown', function (e) {
            e.preventDefault();
            e.stopPropagation();
          });
          removeBtn.addEventListener('click', function (e) {
            e.preventDefault();
            e.stopPropagation();
            removeTag(kind, index);
          });
        })(item.kind, item.index);
        tag.appendChild(removeBtn);
        filterTagsRow.appendChild(tag);
      }
    }

    function addTag(kind, value) {
      if (!value || ('' + value).trim().length === 0) { return; }
      var trimmed = ('' + value).trim();
      var arr = kind === 'branch' ? state.selectedBranches : state.selectedAuthors;
      if (arr.indexOf(trimmed) >= 0) { return; }
      arr.push(trimmed);
      var input = kind === 'branch' ? branchInput : authorInput;
      renderTags();
      if (input) { input.value = ''; input.focus(); }
      noteFilterInputChanged();
    }

    function removeTag(kind, index) {
      var arr = kind === 'branch' ? state.selectedBranches : state.selectedAuthors;
      if (index < 0 || index >= arr.length) { return; }
      arr.splice(index, 1);
      renderTags();
      noteFilterInputChanged();
    }

    function createAutocomplete(input, list, options = {}) {
      const applyOnInput = options.applyOnInput !== false;
      const onSelect = typeof options.onSelect === 'function' ? options.onSelect : undefined;
      const model = { source: [], suggestions: [], activeIndex: -1 };
      const close = () => {
        model.suggestions = [];
        model.activeIndex = -1;
        list.classList.remove('visible');
        list.innerHTML = '';
      };
      const focusActive = () => {
        const active = list.querySelector('.autocomplete-option.active');
        if (active && active.scrollIntoView) {
          active.scrollIntoView({ block: 'nearest' });
        }
      };
      const render = () => {
        if (model.suggestions.length === 0) {
          close();
          return;
        }
        list.innerHTML = model.suggestions.map((value, index) => {
          const active = index === model.activeIndex ? ' active' : '';
          return '<button type="button" class="autocomplete-option' + active + '" data-index="' + index + '" role="option" aria-selected="' + (index === model.activeIndex ? 'true' : 'false') + '">' + escapeHtml(value) + '</button>';
        }).join('');
        list.classList.add('visible');
        focusActive();
      };
      const compute = (keyword) => {
        const key = (keyword || '').trim().toLowerCase();
        model.suggestions = model.source
          .map((value) => {
            const lower = String(value).toLowerCase();
            return { value, score: scoreMatch(lower, key), index: lower.indexOf(key) };
          })
          .filter((item) => Number.isFinite(item.score))
          .sort((a, b) => {
            if (a.score !== b.score) { return a.score - b.score; }
            if (a.index !== b.index) { return a.index - b.index; }
            return a.value.localeCompare(b.value);
          })
          .map((item) => item.value);
        model.activeIndex = model.suggestions.length > 0 ? 0 : -1;
      };
      const open = () => {
        compute(input.value);
        render();
      };
      const select = (index) => {
        const selected = model.suggestions[index];
        if (!selected) { return; }
        input.value = selected;
        inputRevision += 1;
        if (onSelect) { onSelect(selected); }
        close();
        renderPreview();
        scheduleApplyFilters();
      };
      input.addEventListener('input', () => {
        open();
        if (applyOnInput) {
          noteFilterInputChanged();
        } else {
          noteFilterTextChanged();
        }
      });
      input.addEventListener('focus', open);
      input.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowDown') {
          if (model.suggestions.length === 0) { open(); }
          if (model.suggestions.length > 0) {
            event.preventDefault();
            model.activeIndex = (model.activeIndex + 1 + model.suggestions.length) % model.suggestions.length;
            render();
          }
          return;
        }
        if (event.key === 'ArrowUp') {
          if (model.suggestions.length === 0) { open(); }
          if (model.suggestions.length > 0) {
            event.preventDefault();
            model.activeIndex = (model.activeIndex - 1 + model.suggestions.length) % model.suggestions.length;
            render();
          }
          return;
        }
        if (event.key === 'Enter' && model.activeIndex >= 0 && model.suggestions.length > 0) {
          event.preventDefault();
          select(model.activeIndex);
          return;
        }
        if (event.key === 'Escape') {
          close();
        }
      });
      list.addEventListener('mousedown', (event) => event.preventDefault());
      list.addEventListener('click', (event) => {
        const option = event.target && event.target.closest ? event.target.closest('.autocomplete-option') : null;
        if (!option) { return; }
        const index = Number(option.getAttribute('data-index') || '-1');
        if (index >= 0) {
          select(index);
        }
      });
      document.addEventListener('click', (event) => {
        const target = event.target;
        if (target === input || list.contains(target)) { return; }
        close();
      });
      return {
        setSource(values) {
          model.source = Array.isArray(values) ? values : [];
        },
        close
      };
    }

    const branchAutocomplete = createAutocomplete(branchInput, document.getElementById('branch-list'), {
      applyOnInput: false,
      onSelect: function (branch) {
        addTag('branch', branch);
      }
    });
    const authorAutocomplete = createAutocomplete(authorInput, document.getElementById('author-list'), {
      applyOnInput: false,
      onSelect: function (author) {
        addTag('author', author);
      }
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (document.activeElement === branchInput || document.activeElement === authorInput) {
        return;
      }
      if (SHOW_APPLY) {
        scheduleApplyFilters();
      }
    });

    if (cancelButton) {
      cancelButton.addEventListener('click', () => {
        vscode.postMessage({ type: 'close' });
      });
    }

    if (clearButton) {
      clearButton.addEventListener('click', () => {
        cancelPendingApply();
        clearFilterInputs();
        if (SHOW_APPLY) {
          renderPreview();
          vscode.postMessage({ type: 'clear' });
          return;
        }
        renderPreview();
        scheduleApplyFilters();
      });
    }

    fieldClearButtons.forEach((button) => {
      button.addEventListener('mousedown', (event) => event.preventDefault());
      button.addEventListener('click', () => {
        const targetId = button.getAttribute('data-target') || '';
        const target = document.getElementById(targetId);
        if (!target) { return; }
        target.value = '';
        if (targetId === 'branch') {
          state.selectedBranches = [];
          renderTags();
          branchAutocomplete.close();
        }
        if (targetId === 'author') {
          state.selectedAuthors = [];
          renderTags();
          authorAutocomplete.close();
        }
        noteFilterInputChanged();
      });
    });
    [messageInput, sinceInput, untilInput].forEach((input) => {
      input.addEventListener('input', noteFilterInputChanged);
      input.addEventListener('change', noteFilterInputChanged);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        e.preventDefault();
        if (commitContextMenu.isVisible()) {
          commitContextMenu.close();
          return;
        }
        vscode.postMessage({ type: 'close' });
      }
    });

    // Enter on branch/author input adds a tag; Backspace on empty removes last tag
    if (branchInput) {
      branchInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          var val = branchInput.value.trim();
          if (val.length > 0) {
            addTag('branch', val);
          }
        }
        if (e.key === 'Backspace' && branchInput.value === '' && state.selectedBranches.length > 0) {
          removeTag('branch', state.selectedBranches.length - 1);
        }
      });
    }
    if (authorInput) {
      authorInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          var val = authorInput.value.trim();
          if (val.length > 0) {
            addTag('author', val);
          }
        }
        if (e.key === 'Backspace' && authorInput.value === '' && state.selectedAuthors.length > 0) {
          removeTag('author', state.selectedAuthors.length - 1);
        }
      });
    }

    const loadMoreSentinel = document.getElementById('load-more-sentinel');

    function attachLoadMoreObserver() {
      if (!loadMoreSentinel || typeof IntersectionObserver === 'undefined') { return; }
      loadMoreObserver = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && state.hasMore && !state.loading && !state.loadMoreErrored) {
          state.loading = true;
          vscode.postMessage({ type: 'loadMore' });
        }
      }, { threshold: 0.1 });
      loadMoreObserver.observe(loadMoreSentinel);
    }
  </script>
