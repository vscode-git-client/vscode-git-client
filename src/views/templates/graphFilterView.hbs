{{> partials/documentStart title=title}}
    {{> partials/styles/theme}}
    {{> partials/styles/contextMenu minWidth="260px"}}
    {{> partials/styles/bodyBase background="var(--bg)" padding="14px 16px" gap="10px"}}
    {{> partials/styles/viewHeading titleSize="14px"}}
    form {
      display: flex;
      flex-direction: column;
      gap: 10px;
      min-height: 0;
      flex: 1;
    }
    .filters-inline {
      display: grid;
      gap: 8px;
      grid-template-columns: minmax(160px, 1fr) minmax(160px, 1fr) minmax(160px, 1fr) minmax(132px, 160px) minmax(132px, 160px);
      align-items: end;
      --filter-label-weight: 600;
      --filter-input-border: var(--vscode-input-border, var(--border));
      --filter-input-background: var(--vscode-input-background);
      --filter-input-color: var(--vscode-input-foreground);
      --filter-input-padding: 7px 8px;
      --filter-input-font-family: var(--vscode-font-family);
    }
    {{> partials/styles/filterFieldAtoms}}
    {{> partials/styles/fieldClear}}
    {{> partials/styles/autocomplete listClass="autocomplete-list" optionClass="autocomplete-option" shadowAlpha="0.25"}}
    .actions {
      display: flex;
      gap: 8px;
      justify-content: flex-end;
      align-items: center;
      border-top: 1px solid var(--border);
      padding-top: 8px;
    }
    .actions button {
      padding: 6px 12px;
      font-size: 12px;
      border-radius: 4px;
      cursor: pointer;
      font-family: inherit;
    }
    .actions button.primary {
      background: var(--vscode-button-background);
      color: var(--vscode-button-foreground);
      border: 1px solid var(--vscode-button-background);
    }
    .actions button.primary:hover {
      background: var(--vscode-button-hoverBackground);
    }
    {{> partials/styles/outlineButton
      selector=".actions button.secondary"
      padding="6px 12px"
      radius="4px"
      fontSize="12px"
      color="var(--vscode-button-secondaryForeground, var(--fg))"
      background="var(--vscode-button-secondaryBackground, transparent)"
      hoverBorderColor="var(--accent)"
    }}
    .commit-preview {
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      min-height: 0;
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .preview-header {
      font-size: 11px;
      color: var(--muted);
      padding: 6px 8px;
      border-bottom: 1px solid var(--border);
    }
    {{> partials/styles/flexScrollArea className="preview-table-wrap" overflow="auto"}}
    {{> partials/styles/tableBase cellPadding="6px 4px"}}
    {{> partials/styles/commitListBase}}
  </style>
</head>
<body>
  {{> partials/molecules/viewHeading title=title hint=hint}}

  <form id="form">
    <section class="filters-inline">
      {{> partials/molecules/textFilterField
        id="message"
        name="message"
        label="Message"
        note="(subject/id)"
        placeholder="fix login, HOTFIX-123, short SHA"
        clearLabel="message"
        autofocus=true
        spellcheck="false"
      }}
      {{> partials/molecules/textFilterField
        id="branch"
        name="branch"
        label="Branch"
        placeholder="main, feature/login"
        clearLabel="branch"
        autocompleteAttr="off"
        spellcheck="false"
        autocompleteId="branch-list"
        autocompleteClass="autocomplete-list"
        autocompleteLabel="Branch suggestions"
      }}
      {{> partials/molecules/textFilterField
        id="author"
        name="author"
        label="Author"
        placeholder="name or email"
        clearLabel="author"
        autocompleteAttr="off"
        spellcheck="false"
        autocompleteId="author-list"
        autocompleteClass="autocomplete-list"
        autocompleteLabel="Author suggestions"
      }}
      {{> partials/molecules/dateFilterField
        id="since"
        name="since"
        label="Since"
        clearLabel="since"
      }}
      {{> partials/molecules/dateFilterField
        id="until"
        name="until"
        label="Until"
        clearLabel="until"
      }}
    </section>

    <section class="commit-preview">
      <div class="preview-header" id="preview-header">Matching commits: 0</div>
      <div class="preview-table-wrap">
        {{> partials/commitTable tbodyId="preview-body"}}
        <div id="load-more-sentinel" style="height:1px"></div>
      </div>
    </section>

    {{#unless showApply}}
      <div class="actions">
        <button type="button" class="secondary" id="cancel">Close</button>
        <button type="button" class="secondary" id="clear">Clear Filters</button>
      </div>
    {{/unless}}
  </form>

  {{> partials/graphContextMenu}}

  <script>
    const vscode = acquireVsCodeApi();
    const form = document.getElementById('form');
    const SHOW_APPLY = {{#if showApply}}true{{else}}false{{/if}};
    const state = {
      branches: [],
      authors: [],
      commits: [],
      loading: false,
      hasMore: false,
      loadMoreErrored: false
    };
    const messageInput = document.getElementById('message');
    const branchInput = document.getElementById('branch');
    const authorInput = document.getElementById('author');
    const sinceInput = document.getElementById('since');
    const untilInput = document.getElementById('until');
    const previewHeader = document.getElementById('preview-header');
    const previewBody = document.getElementById('preview-body');
    const cancelButton = document.getElementById('cancel');
    const clearButton = document.getElementById('clear');
    const fieldClearButtons = Array.from(document.querySelectorAll('.field-clear'));
    let applyDebounceTimer = null;
    let loadMoreObserver = null;
    let inputRevision = 0;
    let selectedBranchFilter = '';

    {{> partials/scripts/commitContextMenu}}

    let selectionAnchorSha = null;

    const getVisibleCommitRows = () =>
      Array.from(document.querySelectorAll('.commit-row')).filter((row) => row.style.display !== 'none');
    const getCommitSha = (row) => (row && row.getAttribute ? row.getAttribute('data-sha') || '' : '');
    const isCommitRowSelected = (row) => Boolean(row && row.classList && row.classList.contains('selected'));
    const setCommitRowSelected = (row, selected) => {
      if (!row || !row.classList) { return; }
      row.classList.toggle('selected', selected);
      row.setAttribute('aria-selected', selected ? 'true' : 'false');
    };
    const clearCommitSelection = () => {
      Array.from(document.querySelectorAll('.commit-row.selected')).forEach((row) => setCommitRowSelected(row, false));
    };
    const getSelectedCommitRows = () =>
      Array.from(document.querySelectorAll('.commit-row.selected')).filter((row) => row.style.display !== 'none');
    const getSelectedCommitShas = () =>
      Array.from(new Set(getSelectedCommitRows().map((row) => getCommitSha(row)).filter(Boolean)));

    const selectRange = (targetRow, additive) => {
      const visibleRows = getVisibleCommitRows();
      const targetSha = getCommitSha(targetRow);
      const anchorIndex = visibleRows.findIndex((row) => getCommitSha(row) === selectionAnchorSha);
      const targetIndex = visibleRows.findIndex((row) => getCommitSha(row) === targetSha);
      if (targetIndex < 0) {
        return;
      }
      if (anchorIndex < 0) {
        if (!additive) {
          clearCommitSelection();
        }
        setCommitRowSelected(targetRow, true);
        selectionAnchorSha = targetSha || selectionAnchorSha;
        return;
      }
      const from = Math.min(anchorIndex, targetIndex);
      const to = Math.max(anchorIndex, targetIndex);
      if (!additive) {
        clearCommitSelection();
      }
      for (let index = from; index <= to; index += 1) {
        setCommitRowSelected(visibleRows[index], true);
      }
    };

    const updateSelection = (row, event, options = {}) => {
      if (!row) {
        return;
      }
      const forContextMenu = Boolean(options.forContextMenu);
      const toggle = Boolean(event && (event.ctrlKey || event.metaKey));
      const range = Boolean(event && event.shiftKey);
      const sha = getCommitSha(row);

      if (range) {
        selectRange(row, toggle);
        if (sha) {
          selectionAnchorSha = sha;
        }
        return;
      }

      if (toggle) {
        setCommitRowSelected(row, !isCommitRowSelected(row));
        if (sha) {
          selectionAnchorSha = sha;
        }
        return;
      }

      if (forContextMenu && isCommitRowSelected(row)) {
        if (sha) {
          selectionAnchorSha = sha;
        }
        return;
      }

      clearCommitSelection();
      setCommitRowSelected(row, true);
      if (sha) {
        selectionAnchorSha = sha;
      }
    };

    window.addEventListener('message', (event) => {
      const msg = event.data;
      if (msg && msg.type === 'loading') {
        state.loading = Boolean(msg.loading);
        renderPreview();
        return;
      }
      if (msg && msg.type === 'init') {
        const responseInputRevision = Number(msg.inputRevision);
        if (Number.isFinite(responseInputRevision) && responseInputRevision < inputRevision) {
          return;
        }
        if (loadMoreObserver) { loadMoreObserver.disconnect(); loadMoreObserver = null; }
        state.loading = false;
        state.loadMoreErrored = false;
        state.hasMore = Boolean(msg.hasMore);
        const f = msg.filters || {};
        messageInput.value = f.message || '';
        branchInput.value = f.branch || '';
        selectedBranchFilter = f.branch || '';
        authorInput.value = f.author || '';
        sinceInput.value = f.since || '';
        untilInput.value = f.until || '';
        state.branches = Array.isArray(msg.branches) ? msg.branches : [];
        state.commits = Array.isArray(msg.commits) ? msg.commits : [];
        state.authors = Array.from(
          new Set(state.commits.map((c) => (typeof c.author === 'string' ? c.author.trim() : '')).filter(Boolean))
        ).sort((a, b) => a.localeCompare(b));
        branchAutocomplete.setSource(state.branches);
        authorAutocomplete.setSource(state.authors);
        renderPreview();
        if (state.hasMore) { attachLoadMoreObserver(); }
        return;
      }
      if (msg && msg.type === 'appendCommits') {
        state.loading = false;
        state.loadMoreErrored = false;
        state.hasMore = Boolean(msg.hasMore);
        const newCommits = Array.isArray(msg.commits) ? msg.commits : [];
        state.commits = state.commits.concat(newCommits);
        const newAuthors = newCommits
          .map((c) => (typeof c.author === 'string' ? c.author.trim() : ''))
          .filter(Boolean);
        if (newAuthors.length > 0) {
          state.authors = Array.from(new Set([...state.authors, ...newAuthors])).sort((a, b) => a.localeCompare(b));
          authorAutocomplete.setSource(state.authors);
        }
        appendRows(newCommits);
        return;
      }
      if (msg && msg.type === 'loadMoreError') {
        state.loading = false;
        state.loadMoreErrored = true;
        previewHeader.textContent = previewHeader.textContent + ' — error loading more (re-apply filters to retry)';
        return;
      }
    });

    function escapeHtml(value) {
      return String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    }

    function parseSince(value) {
      if (!value) { return undefined; }
      const timestamp = new Date(value + 'T00:00:00').getTime();
      return Number.isFinite(timestamp) ? timestamp : undefined;
    }

    function parseUntil(value) {
      if (!value) { return undefined; }
      const timestamp = new Date(value + 'T23:59:59.999').getTime();
      return Number.isFinite(timestamp) ? timestamp : undefined;
    }

    function renderGraphGlyph(graph) {
      if (graph === '<') { return '◀'; }
      if (graph === '>') { return '▶'; }
      if (graph === '-') { return '●'; }
      return '○';
    }

    function buildRow(commit) {
      const sha = escapeHtml(commit.sha || '');
      const subject = escapeHtml(commit.subject || '');
      const author = escapeHtml(commit.author || '');
      const timestamp = Number(commit.dateTimestamp || 0);
      const full = escapeHtml(commit.dateTitle || '');
      const dateText = escapeHtml(commit.dateLabel || '');
      const graph = escapeHtml(renderGraphGlyph(commit.graph));
      return '<tr class="commit-row" data-sha="' + sha + '" data-subject="' + subject + '" data-author="' + author + '" data-timestamp="' + timestamp + '" data-side="filter" title="' + sha + '"><td class="col-graph copyable" title="Copy commit id: ' + sha + '">' + graph + '</td><td class="col-subject" title="' + subject + '">' + subject + '</td><td class="col-author" title="' + author + '">' + author + '</td><td class="col-date muted"><span title="' + full + '">' + dateText + '</span></td></tr>';
    }

    function scoreMatch(candidate, keyword) {
      if (!keyword) { return 3; }
      const i = candidate.indexOf(keyword);
      if (i < 0) { return Number.POSITIVE_INFINITY; }
      if (i === 0) { return 0; }
      if (candidate[i - 1] === ' ' || candidate[i - 1] === '/' || candidate[i - 1] === '-') { return 1; }
      return 2;
    }

    function collect() {
      return {
        message: messageInput.value,
        branch: selectedBranchFilter,
        author: authorInput.value,
        since: sinceInput.value,
        until: untilInput.value
      };
    }

    function scheduleApplyFilters() {
      if (!SHOW_APPLY) {
        return;
      }
      if (applyDebounceTimer !== null) {
        clearTimeout(applyDebounceTimer);
      }
      applyDebounceTimer = setTimeout(() => {
        applyDebounceTimer = null;
        vscode.postMessage({ type: 'apply', filters: collect(), inputRevision });
      }, 300);
    }

    function cancelPendingApply() {
      if (applyDebounceTimer !== null) {
        clearTimeout(applyDebounceTimer);
        applyDebounceTimer = null;
      }
    }

    function clearFilterInputs() {
      messageInput.value = '';
      branchInput.value = '';
      selectedBranchFilter = '';
      authorInput.value = '';
      sinceInput.value = '';
      untilInput.value = '';
      branchAutocomplete.close();
      authorAutocomplete.close();
      inputRevision += 1;
    }

    function noteFilterInputChanged() {
      inputRevision += 1;
      renderPreview();
      scheduleApplyFilters();
    }

    function noteFilterTextChanged() {
      inputRevision += 1;
      renderPreview();
    }

    function buildMatchPredicate(f) {
      const message = (f.message || '').trim().toLowerCase();
      const author = (f.author || '').trim().toLowerCase();
      const since = parseSince(f.since || '');
      const until = parseUntil(f.until || '');
      return function matchesFilter(commit) {
        const subject = String(commit.subject || '').toLowerCase();
        const sha = String(commit.sha || '').toLowerCase();
        const authorLower = String(commit.author || '').toLowerCase();
        const commitDate = Number(commit.dateTimestamp || 0);
        const messageOk = !message || subject.includes(message) || sha.includes(message);
        const authorOk = !author || authorLower.includes(author);
        const sinceOk = since === undefined || (Number.isFinite(commitDate) && commitDate >= since);
        const untilOk = until === undefined || (Number.isFinite(commitDate) && commitDate <= until);
        return messageOk && authorOk && sinceOk && untilOk;
      };
    }

    function getFilteredCommits() {
      return state.commits.filter(buildMatchPredicate(collect()));
    }

    function updatePreviewHeader() {
      const filtered = getFilteredCommits();
      const suffix = state.hasMore ? ' (scroll to load more)' : '';
      previewHeader.textContent = 'Matching commits: ' + filtered.length + suffix;
    }

    function renderPreview() {
      if (state.loading) {
        previewHeader.textContent = 'Loading commits...';
        previewBody.innerHTML = '<tr><td colspan="4">Loading commits...</td></tr>';
        return;
      }
      const filtered = getFilteredCommits();
      updatePreviewHeader();
      if (filtered.length === 0) {
        previewBody.innerHTML = '<tr><td colspan="4">No commits match current filters</td></tr>';
        return;
      }
      previewBody.innerHTML = filtered.map(buildRow).join('');
    }

    function renderEmptyStateIfNeeded() {
      if (!previewBody.querySelector('.commit-row')) {
        previewBody.innerHTML = '<tr><td colspan="4">No commits match current filters</td></tr>';
      }
    }

    function appendRows(newCommits) {
      const matchingRows = newCommits.filter(buildMatchPredicate(collect())).map(buildRow);

      if (matchingRows.length > 0 && previewBody.querySelector('td[colspan]')) {
        previewBody.innerHTML = '';
      }

      if (matchingRows.length > 0) {
        previewBody.insertAdjacentHTML('beforeend', matchingRows.join(''));
      } else {
        renderEmptyStateIfNeeded();
      }

      updatePreviewHeader();
    }

    document.addEventListener('click', (event) => {
      if (commitContextMenu.isVisible()) {
        if (!commitContextMenu.contains(event.target)) { commitContextMenu.close(); }
        return;
      }
      const row = event.target && event.target.closest ? event.target.closest('.commit-row') : null;
      if (!row) { return; }
      const sha = row.getAttribute('data-sha') || '';
      if (!sha) { return; }
      const hasMultiModifier = event.shiftKey || event.ctrlKey || event.metaKey;
      updateSelection(row, event);
      if (hasMultiModifier) {
        const selectedShas = getSelectedCommitShas();
        if (selectedShas.length > 1) {
          vscode.postMessage({ type: 'openCommitRangeDetails', shas: selectedShas });
        }
        return;
      }
      const graphCell = event.target && event.target.closest ? event.target.closest('.col-graph.copyable') : null;
      if (graphCell) {
        event.stopPropagation();
        vscode.postMessage({ type: 'commitAction', action: 'copyRevisionNumber', sha });
        return;
      }
      const subject = row.getAttribute('data-subject') || '';
      vscode.postMessage({ type: 'openCommitDetails', sha, subject });
    });

    document.addEventListener('contextmenu', (event) => {
      const row = event.target && event.target.closest ? event.target.closest('.commit-row') : null;
      if (!row) {
        commitContextMenu.close();
        return;
      }
      updateSelection(row, event, { forContextMenu: true });
      row._vscodeGitClientSelectedShas = getSelectedCommitShas();
      row._vscodeGitClientSelectedSubjects = getSelectedCommitRows()
        .map((item) => (item.getAttribute('data-subject') || '').trim())
        .filter(Boolean);
      commitContextMenu.openForRow(event, row);
    });

    function createAutocomplete(input, list, options = {}) {
      const applyOnInput = options.applyOnInput !== false;
      const onSelect = typeof options.onSelect === 'function' ? options.onSelect : undefined;
      const model = { source: [], suggestions: [], activeIndex: -1 };
      const close = () => {
        model.suggestions = [];
        model.activeIndex = -1;
        list.classList.remove('visible');
        list.innerHTML = '';
      };
      const focusActive = () => {
        const active = list.querySelector('.autocomplete-option.active');
        if (active && active.scrollIntoView) {
          active.scrollIntoView({ block: 'nearest' });
        }
      };
      const render = () => {
        if (model.suggestions.length === 0) {
          close();
          return;
        }
        list.innerHTML = model.suggestions.map((value, index) => {
          const active = index === model.activeIndex ? ' active' : '';
          return '<button type="button" class="autocomplete-option' + active + '" data-index="' + index + '" role="option" aria-selected="' + (index === model.activeIndex ? 'true' : 'false') + '">' + escapeHtml(value) + '</button>';
        }).join('');
        list.classList.add('visible');
        focusActive();
      };
      const compute = (keyword) => {
        const key = (keyword || '').trim().toLowerCase();
        model.suggestions = model.source
          .map((value) => {
            const lower = String(value).toLowerCase();
            return { value, score: scoreMatch(lower, key), index: lower.indexOf(key) };
          })
          .filter((item) => Number.isFinite(item.score))
          .sort((a, b) => {
            if (a.score !== b.score) { return a.score - b.score; }
            if (a.index !== b.index) { return a.index - b.index; }
            return a.value.localeCompare(b.value);
          })
          .map((item) => item.value);
        model.activeIndex = model.suggestions.length > 0 ? 0 : -1;
      };
      const open = () => {
        compute(input.value);
        render();
      };
      const select = (index) => {
        const selected = model.suggestions[index];
        if (!selected) { return; }
        input.value = selected;
        inputRevision += 1;
        if (onSelect) { onSelect(selected); }
        close();
        renderPreview();
        scheduleApplyFilters();
      };
      input.addEventListener('input', () => {
        open();
        if (applyOnInput) {
          noteFilterInputChanged();
        } else {
          noteFilterTextChanged();
        }
      });
      input.addEventListener('focus', open);
      input.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowDown') {
          if (model.suggestions.length === 0) { open(); }
          if (model.suggestions.length > 0) {
            event.preventDefault();
            model.activeIndex = (model.activeIndex + 1 + model.suggestions.length) % model.suggestions.length;
            render();
          }
          return;
        }
        if (event.key === 'ArrowUp') {
          if (model.suggestions.length === 0) { open(); }
          if (model.suggestions.length > 0) {
            event.preventDefault();
            model.activeIndex = (model.activeIndex - 1 + model.suggestions.length) % model.suggestions.length;
            render();
          }
          return;
        }
        if (event.key === 'Enter' && model.activeIndex >= 0 && model.suggestions.length > 0) {
          event.preventDefault();
          select(model.activeIndex);
          return;
        }
        if (event.key === 'Escape') {
          close();
        }
      });
      list.addEventListener('mousedown', (event) => event.preventDefault());
      list.addEventListener('click', (event) => {
        const option = event.target && event.target.closest ? event.target.closest('.autocomplete-option') : null;
        if (!option) { return; }
        const index = Number(option.getAttribute('data-index') || '-1');
        if (index >= 0) {
          select(index);
        }
      });
      document.addEventListener('click', (event) => {
        const target = event.target;
        if (target === input || list.contains(target)) { return; }
        close();
      });
      return {
        setSource(values) {
          model.source = Array.isArray(values) ? values : [];
        },
        close
      };
    }

    const branchAutocomplete = createAutocomplete(branchInput, document.getElementById('branch-list'), {
      applyOnInput: false,
      onSelect: (branch) => {
        selectedBranchFilter = branch;
      }
    });
    const authorAutocomplete = createAutocomplete(authorInput, document.getElementById('author-list'));

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (document.activeElement === branchInput) {
        return;
      }
      if (SHOW_APPLY) {
        scheduleApplyFilters();
      }
    });

    if (cancelButton) {
      cancelButton.addEventListener('click', () => {
        vscode.postMessage({ type: 'close' });
      });
    }

    if (clearButton) {
      clearButton.addEventListener('click', () => {
        cancelPendingApply();
        clearFilterInputs();
        if (SHOW_APPLY) {
          renderPreview();
          vscode.postMessage({ type: 'clear' });
          return;
        }
        renderPreview();
        scheduleApplyFilters();
      });
    }

    fieldClearButtons.forEach((button) => {
      button.addEventListener('mousedown', (event) => event.preventDefault());
      button.addEventListener('click', () => {
        const targetId = button.getAttribute('data-target') || '';
        const target = document.getElementById(targetId);
        if (!target) { return; }
        target.value = '';
        if (targetId === 'branch') {
          selectedBranchFilter = '';
          branchAutocomplete.close();
        }
        if (targetId === 'author') { authorAutocomplete.close(); }
        noteFilterInputChanged();
      });
    });
    [messageInput, sinceInput, untilInput].forEach((input) => {
      input.addEventListener('input', noteFilterInputChanged);
      input.addEventListener('change', noteFilterInputChanged);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        e.preventDefault();
        if (commitContextMenu.isVisible()) {
          commitContextMenu.close();
          return;
        }
        vscode.postMessage({ type: 'close' });
      }
    });

    const loadMoreSentinel = document.getElementById('load-more-sentinel');

    function attachLoadMoreObserver() {
      if (!loadMoreSentinel || typeof IntersectionObserver === 'undefined') { return; }
      loadMoreObserver = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && state.hasMore && !state.loading && !state.loadMoreErrored) {
          state.loading = true;
          vscode.postMessage({ type: 'loadMore' });
        }
      }, { threshold: 0.1 });
      loadMoreObserver.observe(loadMoreSentinel);
    }
  </script>
{{> partials/documentEnd}}
