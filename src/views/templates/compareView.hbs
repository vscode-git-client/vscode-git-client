{{> partials/documentStart title="Branch Comparison"}}
    {{> partials/styles/theme}}
    {{> partials/styles/contextMenu minWidth="260px"}}
    {{> partials/styles/bodyBase background="linear-gradient(145deg, color-mix(in srgb, var(--bg), transparent 0%), color-mix(in srgb, var(--accent), transparent 92%))" padding="16px" gap="0"}}
    .grid {
      display: flex;
      flex-direction: column;
      gap: 16px;
      flex: 2;
      min-height: 0;
      margin-bottom: 16px;
    }
    .filters {
      display: grid;
      grid-template-columns: minmax(180px, 1fr) minmax(180px, 1fr) minmax(150px, 180px) minmax(150px, 180px) auto;
      gap: 8px;
      margin-bottom: 12px;
      align-items: end;
      --filter-label-weight: 400;
      --filter-input-border: var(--border);
      --filter-input-background: color-mix(in srgb, var(--bg), white 4%);
      --filter-input-color: var(--fg);
      --filter-input-padding: 6px 8px;
      --filter-input-font-family: inherit;
    }
    {{> partials/styles/filterFieldAtoms}}
    .filter-input.invalid {
      border-color: var(--vscode-inputValidation-errorBorder, #d93025);
    }
    {{> partials/styles/fieldClear}}
    .filter-actions {
      display: flex;
      justify-content: flex-end;
      align-items: flex-end;
      height: 100%;
    }
    {{> partials/styles/outlineButton
      selector=".filter-clear"
      padding="6px 10px"
      hoverBackground="color-mix(in srgb, var(--accent), transparent 90%)"
    }}
    .filter-options {
      grid-column: 1 / -1;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 16px;
      padding-top: 2px;
    }
    .filter-options-actions {
      margin-left: auto;
      display: flex;
      align-items: center;
    }
    {{> partials/styles/outlineButton
      selector=".filter-export"
      padding="6px 10px"
      hoverBackground="color-mix(in srgb, var(--accent), transparent 90%)"
    }}
    .filter-checkbox-label {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: var(--muted);
      cursor: pointer;
      user-select: none;
    }
    .filter-checkbox-label input {
      margin: 0;
      cursor: pointer;
    }
    {{> partials/styles/autocomplete listClass="author-autocomplete" optionClass="author-option" shadowAlpha="0.2"}}
    .card {
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 12px;
      background: color-mix(in srgb, var(--bg), white 3%);
      min-width: 0;
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .card .section-banner {
      margin: 0 0 8px;
      flex-shrink: 0;
      font-size: 11px;
      line-height: 1.4;
      color: var(--vscode-editorWarning-foreground);
      border: 1px solid color-mix(in srgb, var(--vscode-editorWarning-foreground), transparent 65%);
      background: color-mix(in srgb, var(--vscode-editorWarning-foreground), transparent 92%);
      border-radius: 6px;
      padding: 4px 8px;
    }
    {{> partials/styles/flexScrollArea className="table-wrap" overflow="auto"}}
    {{> partials/styles/tableBase cellPadding="6px 4px"}}
    {{> partials/styles/commitListBase}}
  </style>
</head>
<body>
  <section class="filters">
    {{> partials/molecules/textFilterField
      id="filter-author"
      label="Author"
      placeholder="Type author name"
      clearLabel="Author"
      autocompleteAttr="off"
      autocompleteId="author-autocomplete"
      autocompleteClass="author-autocomplete"
      autocompleteLabel="Author suggestions"
    }}
    {{> partials/molecules/textFilterField
      id="filter-exclude-message"
      label="Exclude message (regex)"
      placeholder="Merge pull request|WIP"
      clearLabel="Exclude message regex"
      autocompleteAttr="off"
      spellcheck="false"
    }}
    {{> partials/molecules/dateFilterField
      id="filter-since"
      label="From date"
      clearLabel="From date"
    }}
    {{> partials/molecules/dateFilterField
      id="filter-until"
      label="To date"
      clearLabel="To date"
    }}
    <div class="filter-actions">
      <button id="filter-clear" class="filter-clear" type="button">Clear filters</button>
    </div>
    <div class="filter-options">
      <label
        class="filter-checkbox-label"
        for="filter-ignore-merges"
        title='Ignore commits that have message "Merge branch ..."'
      >
        <input id="filter-ignore-merges" type="checkbox" />
        <span>Ignore merge commits</span>
      </label>
      <label
        class="filter-checkbox-label"
        for="filter-matching-messages"
        title="Match commits by Author + DateTime + Message, ignore commit ID"
      >
        <input id="filter-matching-messages" type="checkbox" />
        <span>Matching messages</span>
      </label>
      <div class="filter-options-actions">
        <button id="filter-export-excel" class="filter-export" type="button" title="{{exportButtonLabel}}">{{exportButtonLabel}}</button>
      </div>
    </div>
  </section>
  <div class="grid">
    {{> partials/compareCommitTable side="left" total=leftTotal ref=leftRef rows=leftCommits}}

    {{> partials/compareCommitTable side="right" total=rightTotal ref=rightRef rows=rightCommits}}
  </div>

  {{> partials/compareContextMenu}}

  <script>
    const vscode = acquireVsCodeApi();
    const allAuthors = {{{authorsJson}}};
    const authorInput = document.getElementById('filter-author');
    const authorAutocomplete = document.getElementById('author-autocomplete');
    const excludeMessageInput = document.getElementById('filter-exclude-message');
    const sinceInput = document.getElementById('filter-since');
    const untilInput = document.getElementById('filter-until');
    const ignoreMergesCheckbox = document.getElementById('filter-ignore-merges');
    const matchingMessagesCheckbox = document.getElementById('filter-matching-messages');
    const clearButton = document.getElementById('filter-clear');
    const exportExcelButton = document.getElementById('filter-export-excel');
    const fieldClearButtons = Array.from(document.querySelectorAll('.field-clear'));
    let authorSuggestions = [];
    let authorActiveIndex = -1;

    {{> partials/scripts/commitContextMenu}}

    let selectionAnchorSha = null;
    let activePane = 'left';

    const getVisibleCommitRows = () =>
      Array.from(document.querySelectorAll('.commit-row')).filter((row) => row.style.display !== 'none');
    const getVisibleCommitRowsBySide = (side) =>
      getVisibleCommitRows().filter((row) => row.getAttribute('data-side') === side);
    const getCommitSha = (row) => (row && row.getAttribute ? row.getAttribute('data-sha') || '' : '');
    const getCommitSide = (row) => (row && row.getAttribute ? row.getAttribute('data-side') || '' : '');
    const isCommitRowSelected = (row) => Boolean(row && row.classList && row.classList.contains('selected'));
    const setCommitRowSelected = (row, selected) => {
      if (!row || !row.classList) { return; }
      row.classList.toggle('selected', selected);
      row.setAttribute('aria-selected', selected ? 'true' : 'false');
    };
    const clearCommitSelection = () => {
      Array.from(document.querySelectorAll('.commit-row.selected')).forEach((row) => setCommitRowSelected(row, false));
    };
    const getSelectedCommitRows = () =>
      Array.from(document.querySelectorAll('.commit-row.selected')).filter((row) => row.style.display !== 'none');
    const getSelectedCommitShas = () =>
      Array.from(new Set(getSelectedCommitRows().map((row) => getCommitSha(row)).filter(Boolean)));
    const getPaneRef = (side) => document.querySelector('.section-banner[data-side="' + side + '"]')?.getAttribute('data-ref') || side;
    const isTextInputTarget = (target) => Boolean(
      target &&
      (
        (target.tagName === 'INPUT' && target.type !== 'checkbox' && target.type !== 'radio') ||
        target.tagName === 'TEXTAREA' ||
        target.isContentEditable
      )
    );

    const resolveActivePane = () => {
      if (activePane === 'left' || activePane === 'right') {
        return activePane;
      }
      const selected = getSelectedCommitRows();
      const firstSide = selected.length > 0 ? getCommitSide(selected[0]) : '';
      return firstSide === 'right' ? 'right' : 'left';
    };

    const selectAllVisibleRowsInPane = (side) => {
      const rows = getVisibleCommitRowsBySide(side);
      if (rows.length === 0) {
        clearCommitSelection();
        selectionAnchorSha = null;
        return;
      }
      clearCommitSelection();
      rows.forEach((row) => setCommitRowSelected(row, true));
      selectionAnchorSha = getCommitSha(rows[0]) || null;
      activePane = side;
    };

    const serializeVisibleCommits = (side) =>
      getVisibleCommitRowsBySide(side).map((row) => {
        const dateCell = row.querySelector('.col-date span');
        return {
          sha: row.getAttribute('data-sha') || '',
          subject: row.getAttribute('data-subject') || '',
          author: row.getAttribute('data-author') || '',
          date: (dateCell && (dateCell.getAttribute('title') || dateCell.textContent)) || ''
        };
      });

    const selectRange = (targetRow, additive, side) => {
      const visibleRows = getVisibleCommitRowsBySide(side);
      const targetSha = getCommitSha(targetRow);
      const anchorIndex = visibleRows.findIndex((row) => getCommitSha(row) === selectionAnchorSha);
      const targetIndex = visibleRows.findIndex((row) => getCommitSha(row) === targetSha);
      if (targetIndex < 0) {
        return;
      }
      if (anchorIndex < 0) {
        if (!additive) {
          clearCommitSelection();
        }
        setCommitRowSelected(targetRow, true);
        selectionAnchorSha = targetSha || selectionAnchorSha;
        return;
      }
      const from = Math.min(anchorIndex, targetIndex);
      const to = Math.max(anchorIndex, targetIndex);
      if (!additive) {
        clearCommitSelection();
      }
      for (let index = from; index <= to; index += 1) {
        setCommitRowSelected(visibleRows[index], true);
      }
    };

    const updateSelection = (row, event, options = {}) => {
      if (!row) {
        return;
      }
      const forContextMenu = Boolean(options.forContextMenu);
      const toggle = Boolean(event && (event.ctrlKey || event.metaKey));
      const range = Boolean(event && event.shiftKey);
      const sha = getCommitSha(row);
      const side = getCommitSide(row);
      if (side === 'left' || side === 'right') {
        activePane = side;
      }
      const selectedRows = getSelectedCommitRows();
      if (selectedRows.length > 0) {
        const selectedSide = getCommitSide(selectedRows[0]);
        if ((selectedSide === 'left' || selectedSide === 'right') && selectedSide !== side) {
          clearCommitSelection();
          selectionAnchorSha = null;
        }
      }

      if (range) {
        selectRange(row, toggle, side);
        if (sha) {
          selectionAnchorSha = sha;
        }
        return;
      }

      if (toggle) {
        setCommitRowSelected(row, !isCommitRowSelected(row));
        if (sha) {
          selectionAnchorSha = sha;
        }
        return;
      }

      if (forContextMenu && isCommitRowSelected(row)) {
        if (sha) {
          selectionAnchorSha = sha;
        }
        return;
      }

      clearCommitSelection();
      setCommitRowSelected(row, true);
      if (sha) {
        selectionAnchorSha = sha;
      }
    };

    document.addEventListener('click', (event) => {
      if (commitContextMenu.isVisible()) {
        if (!commitContextMenu.contains(event.target)) { commitContextMenu.close(); }
        return;
      }
      const row = event.target && event.target.closest ? event.target.closest('.commit-row') : null;
      if (!row) { return; }
      const sha = row.getAttribute('data-sha') || '';
      const subject = row.getAttribute('data-subject') || '';
      if (!sha) { return; }
      const hasMultiModifier = event.shiftKey || event.ctrlKey || event.metaKey;
      updateSelection(row, event);
      if (hasMultiModifier) {
        const selectedShas = getSelectedCommitShas();
        if (selectedShas.length > 1) {
          vscode.postMessage({ type: 'commitRangeClick', shas: selectedShas });
        }
        return;
      }
      const graphCell = event.target && event.target.closest ? event.target.closest('.col-graph.copyable') : null;
      if (graphCell) {
        event.stopPropagation();
        vscode.postMessage({ type: 'commitAction', action: 'copyRevisionNumber', sha });
        return;
      }
      vscode.postMessage({ type: 'commitClick', sha, subject });
    });

    document.addEventListener('contextmenu', (event) => {
      const row = event.target && event.target.closest ? event.target.closest('.commit-row') : null;
      if (!row) {
        commitContextMenu.close();
        return;
      }
      updateSelection(row, event, { forContextMenu: true });
      row._vscodeGitClientSelectedShas = getSelectedCommitShas();
      row._vscodeGitClientSelectedSubjects = getSelectedCommitRows()
        .map((item) => (item.getAttribute('data-subject') || '').trim())
        .filter(Boolean);
      commitContextMenu.openForRow(event, row);
    });

    document.addEventListener('keydown', (event) => {
      const key = (event.key || '').toLowerCase();
      if ((event.metaKey || event.ctrlKey) && !event.shiftKey && !event.altKey && key === 'a') {
        if (isTextInputTarget(event.target)) {
          return;
        }
        event.preventDefault();
        selectAllVisibleRowsInPane(resolveActivePane());
        return;
      }

      if (event.key === 'Escape') {
        event.preventDefault();
        commitContextMenu.close();
        clearCommitSelection();
        selectionAnchorSha = null;
      }
    });

    const scoreAuthorMatch = (authorLower, keywordLower) => {
      if (!keywordLower) {
        return 3;
      }
      const startIndex = authorLower.indexOf(keywordLower);
      if (startIndex < 0) {
        return Number.POSITIVE_INFINITY;
      }
      if (startIndex === 0) {
        return 0;
      }
      if (authorLower[startIndex - 1] === ' ') {
        return 1;
      }
      return 2;
    };

    const getSortedAuthorSuggestions = (keyword) => {
      const keywordLower = keyword.trim().toLowerCase();
      return allAuthors
        .map((author) => {
          const lower = author.toLowerCase();
          return {
            author,
            score: scoreAuthorMatch(lower, keywordLower),
            index: lower.indexOf(keywordLower)
          };
        })
        .filter((item) => Number.isFinite(item.score))
        .sort((a, b) => {
          if (a.score !== b.score) { return a.score - b.score; }
          if (a.index !== b.index) { return a.index - b.index; }
          return a.author.localeCompare(b.author);
        })
        .map((item) => item.author);
    };

    const closeAuthorDropdown = () => {
      authorSuggestions = [];
      authorActiveIndex = -1;
      if (!authorAutocomplete) { return; }
      authorAutocomplete.classList.remove('visible');
      authorAutocomplete.innerHTML = '';
    };

    const focusActiveAuthorOption = () => {
      if (!authorAutocomplete || authorActiveIndex < 0) { return; }
      const active = authorAutocomplete.querySelector('.author-option.active');
      if (active && active.scrollIntoView) {
        active.scrollIntoView({ block: 'nearest' });
      }
    };

    const renderAuthorDropdown = () => {
      if (!authorAutocomplete || authorSuggestions.length === 0) {
        closeAuthorDropdown();
        return;
      }
      authorAutocomplete.innerHTML = authorSuggestions
        .map((author, index) => {
          const activeClass = index === authorActiveIndex ? ' active' : '';
          return '<button type="button" class="author-option' + activeClass + '" data-index="' + index + '" role="option" aria-selected="' + (index === authorActiveIndex ? 'true' : 'false') + '">' + author.replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#039;') + '</button>';
        })
        .join('');
      authorAutocomplete.classList.add('visible');
      focusActiveAuthorOption();
    };

    const openAuthorDropdown = (keyword) => {
      authorSuggestions = getSortedAuthorSuggestions(keyword);
      authorActiveIndex = authorSuggestions.length > 0 ? 0 : -1;
      renderAuthorDropdown();
    };

    const selectAuthorSuggestion = (index) => {
      if (!authorInput) { return; }
      const value = authorSuggestions[index];
      if (!value) { return; }
      authorInput.value = value;
      closeAuthorDropdown();
      applyFilters();
    };

    const parseSince = (value) => {
      if (!value) { return undefined; }
      const timestamp = new Date(value + 'T00:00:00').getTime();
      return Number.isFinite(timestamp) ? timestamp : undefined;
    };

    const parseUntil = (value) => {
      if (!value) { return undefined; }
      const timestamp = new Date(value + 'T23:59:59.999').getTime();
      return Number.isFinite(timestamp) ? timestamp : undefined;
    };

    const setInvalidRegexState = (isInvalid) => {
      if (!excludeMessageInput) {
        return;
      }
      excludeMessageInput.classList.toggle('invalid', isInvalid);
      excludeMessageInput.title = isInvalid ? 'Invalid regex' : '';
    };

    const parseExcludeMessageRegex = () => {
      const source = (excludeMessageInput && excludeMessageInput.value ? excludeMessageInput.value : '').trim();
      if (!source) {
        setInvalidRegexState(false);
        return undefined;
      }
      try {
        const regex = new RegExp(source, 'i');
        setInvalidRegexState(false);
        return regex;
      } catch (_error) {
        setInvalidRegexState(true);
        return undefined;
      }
    };

    const isMergeLikeSubject = (subject) => /\bmerge\b/i.test(subject);

    const updateBannerCount = (side, visibleCount) => {
      const banner = document.querySelector('.section-banner[data-side="' + side + '"]');
      if (!banner) { return; }
      const total = Number(banner.getAttribute('data-total') || '0');
      const refName = banner.getAttribute('data-ref') || '';
      const suffix = visibleCount === total ? String(total) : String(visibleCount) + '/' + String(total);
      banner.textContent = 'Only in ' + refName + ' (' + suffix + ')';
    };

    const ensureNoResultsRow = (tbody) => {
      let row = tbody.querySelector('tr.no-filter-results');
      if (!row) {
        row = document.createElement('tr');
        row.className = 'no-filter-results';
        row.innerHTML = '<td colspan="4">No commits match current filters</td>';
        row.style.display = 'none';
        tbody.appendChild(row);
      }
      return row;
    };

    const applyFilters = () => {
      const authorFilter = (authorInput && authorInput.value ? authorInput.value : '').trim().toLowerCase();
      const excludeRegex = parseExcludeMessageRegex();
      const sinceTs = parseSince(sinceInput ? sinceInput.value : '');
      const untilTs = parseUntil(untilInput ? untilInput.value : '');
      const ignoreMerges = Boolean(ignoreMergesCheckbox && ignoreMergesCheckbox.checked);
      const hideMatchingMessages = Boolean(matchingMessagesCheckbox && matchingMessagesCheckbox.checked);
      const visibleBySide = { left: 0, right: 0 };
      const rows = Array.from(document.querySelectorAll('tr.commit-row'));
      const oppositeKeysBySide = {
        left: new Set(),
        right: new Set()
      };
      const baseStates = rows.map((row) => {
        const authorRaw = row.getAttribute('data-author') || '';
        const author = authorRaw.toLowerCase();
        const side = row.getAttribute('data-side') || '';
        const subjectRaw = row.getAttribute('data-subject') || '';
        const subject = subjectRaw.toLowerCase();
        const timestamp = Number(row.getAttribute('data-timestamp') || '0');
        const authorOk = !authorFilter || author.includes(authorFilter);
        const excludeOk = !excludeRegex || !excludeRegex.test(subjectRaw);
        const sinceOk = sinceTs === undefined || timestamp >= sinceTs;
        const untilOk = untilTs === undefined || timestamp <= untilTs;
        const mergeOk = !ignoreMerges || !isMergeLikeSubject(subjectRaw);
        const baseVisible = authorOk && excludeOk && sinceOk && untilOk && mergeOk;
        const matchingKey = [author, String(timestamp), subject].join('\u0000');
        if (baseVisible && (side === 'left' || side === 'right')) {
          oppositeKeysBySide[side].add(matchingKey);
        }
        return { row, side, baseVisible, matchingKey };
      });

      baseStates.forEach((state) => {
        const oppositeSide = state.side === 'left' ? 'right' : 'left';
        const hasMatchOnOpposite = (oppositeSide === 'left' || oppositeSide === 'right') && oppositeKeysBySide[oppositeSide].has(state.matchingKey);
        const visible = state.baseVisible && (!hideMatchingMessages || !hasMatchOnOpposite);
        const row = state.row;
        row.style.display = visible ? '' : 'none';
        if (visible && (state.side === 'left' || state.side === 'right')) {
          visibleBySide[state.side] += 1;
        }
      });

      ['left', 'right'].forEach((side) => {
        updateBannerCount(side, visibleBySide[side]);
        const tbody = document.querySelector('tr.commit-row[data-side="' + side + '"]')?.closest('tbody');
        if (!tbody) { return; }
        const noRow = ensureNoResultsRow(tbody);
        noRow.style.display = visibleBySide[side] === 0 ? '' : 'none';
      });
    };

    if (authorInput) {
      authorInput.addEventListener('input', () => {
        applyFilters();
        openAuthorDropdown(authorInput.value);
      });
      authorInput.addEventListener('focus', () => {
        openAuthorDropdown(authorInput.value);
      });
      authorInput.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowDown') {
          if (authorSuggestions.length === 0) {
            openAuthorDropdown(authorInput.value);
          }
          if (authorSuggestions.length > 0) {
            event.preventDefault();
            authorActiveIndex = (authorActiveIndex + 1 + authorSuggestions.length) % authorSuggestions.length;
            renderAuthorDropdown();
          }
          return;
        }
        if (event.key === 'ArrowUp') {
          if (authorSuggestions.length === 0) {
            openAuthorDropdown(authorInput.value);
          }
          if (authorSuggestions.length > 0) {
            event.preventDefault();
            authorActiveIndex = (authorActiveIndex - 1 + authorSuggestions.length) % authorSuggestions.length;
            renderAuthorDropdown();
          }
          return;
        }
        if (event.key === 'Enter' && authorActiveIndex >= 0 && authorSuggestions.length > 0) {
          event.preventDefault();
          selectAuthorSuggestion(authorActiveIndex);
          return;
        }
        if (event.key === 'Escape') {
          closeAuthorDropdown();
        }
      });
    }
    if (sinceInput) {
      sinceInput.addEventListener('change', applyFilters);
    }
    if (untilInput) {
      untilInput.addEventListener('change', applyFilters);
    }
    if (excludeMessageInput) {
      excludeMessageInput.addEventListener('input', applyFilters);
    }
    if (ignoreMergesCheckbox) {
      ignoreMergesCheckbox.addEventListener('change', applyFilters);
    }
    if (matchingMessagesCheckbox) {
      matchingMessagesCheckbox.addEventListener('change', applyFilters);
    }
    if (clearButton) {
      clearButton.addEventListener('click', () => {
        if (authorInput) { authorInput.value = ''; }
        if (excludeMessageInput) { excludeMessageInput.value = ''; }
        if (sinceInput) { sinceInput.value = ''; }
        if (untilInput) { untilInput.value = ''; }
        if (ignoreMergesCheckbox) { ignoreMergesCheckbox.checked = false; }
        if (matchingMessagesCheckbox) { matchingMessagesCheckbox.checked = false; }
        setInvalidRegexState(false);
        closeAuthorDropdown();
        applyFilters();
      });
    }
    fieldClearButtons.forEach((button) => {
      button.addEventListener('mousedown', (event) => {
        event.preventDefault();
      });
      button.addEventListener('click', () => {
        const targetId = button.getAttribute('data-target') || '';
        if (!targetId) {
          return;
        }
        const target = document.getElementById(targetId);
        if (!target) {
          return;
        }
        target.value = '';
        if (targetId === 'filter-author') {
          closeAuthorDropdown();
          target.focus();
        }
        applyFilters();
      });
    });
    if (authorAutocomplete) {
      authorAutocomplete.addEventListener('mousedown', (event) => {
        event.preventDefault();
      });
      authorAutocomplete.addEventListener('click', (event) => {
        const option = event.target && event.target.closest ? event.target.closest('.author-option') : null;
        if (!option) { return; }
        const index = Number(option.getAttribute('data-index') || '-1');
        if (index >= 0) {
          selectAuthorSuggestion(index);
        }
      });
    }
    document.addEventListener('click', (event) => {
      if (!authorAutocomplete || !authorInput) {
        return;
      }
      const target = event.target;
      if (target === authorInput || authorAutocomplete.contains(target)) {
        return;
      }
      closeAuthorDropdown();
    });
    Array.from(document.querySelectorAll('.commit-row')).forEach((row) => {
      row.addEventListener('mouseenter', () => {
        const side = row.getAttribute('data-side') || '';
        if (side === 'left' || side === 'right') {
          activePane = side;
        }
      });
    });
    if (exportExcelButton) {
      exportExcelButton.addEventListener('click', () => {
        vscode.postMessage({
          type: 'exportCompare',
          format: '{{exportFormat}}',
          leftRef: getPaneRef('left'),
          rightRef: getPaneRef('right'),
          leftCommits: serializeVisibleCommits('left'),
          rightCommits: serializeVisibleCommits('right')
        });
      });
    }
  </script>
