{
  "name": "vscode-git-client",
  "displayName": "IntelliGit Client",
  "description": "IntelliJ-like Git client for VS Code with branch tree, stashes, graph, merge/diff/compare workflows.",
  "version": "0.9.2",
  "publisher": "thanhtunguet",
  "icon": "media/intelligit.png",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/thanhtunguet/IntelliGit"
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:intelliGit.stashes",
    "onView:intelliGit.branches",
    "onView:intelliGit.graph",
    "onView:intelliGit.commitView",
    "onCommand:intelliGit.quickActions"
  ],
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "lint": "eslint src --ext .ts",
    "test": "npm run compile"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "intelliGit",
          "title": "IntelliGit",
          "icon": "media/intelligit.svg"
        }
      ]
    },
    "views": {
      "intelliGit": [
        {
          "id": "intelliGit.branches",
          "name": "Branches",
          "visibility": "visible",
          "icon": "media/intelligit.svg"
        },
        {
          "id": "intelliGit.graph",
          "name": "Git Graph",
          "visibility": "visible",
          "icon": "media/intelligit.svg"
        }
      ],
      "scm": [
        {
          "id": "intelliGit.stashes",
          "name": "IntelliGit Stashes",
          "visibility": "visible"
        }
      ],
      "panel": [
        {
          "id": "intelliGit.commitView",
          "name": "Commit View",
          "when": "intelliGit.commitViewVisible"
        }
      ]
    },
    "commands": [
      {
        "command": "intelliGit.refresh",
        "title": "Refresh"
      },
      {
        "command": "intelliGit.quickActions",
        "title": "Quick Git Actions",
        "icon": "$(ellipsis)"
      },
      {
        "command": "intelliGit.branch.checkout",
        "title": "Checkout Branch"
      },
      {
        "command": "intelliGit.branch.actionHub",
        "title": "Branch Action Hub"
      },
      {
        "command": "intelliGit.branch.create",
        "title": "Create Branch"
      },
      {
        "command": "intelliGit.branch.rename",
        "title": "Rename Branch"
      },
      {
        "command": "intelliGit.branch.delete",
        "title": "Delete Branch"
      },
      {
        "command": "intelliGit.branch.track",
        "title": "Track Remote Branch"
      },
      {
        "command": "intelliGit.branch.untrack",
        "title": "Untrack Branch"
      },
      {
        "command": "intelliGit.branch.mergeIntoCurrent",
        "title": "Merge Into Current"
      },
      {
        "command": "intelliGit.branch.rebaseOnto",
        "title": "Rebase Current Onto Branch"
      },
      {
        "command": "intelliGit.branch.resetCurrentToCommit",
        "title": "Reset Current Branch To Commit"
      },
      {
        "command": "intelliGit.branch.compareWithCurrent",
        "title": "Compare With Current Branch"
      },
      {
        "command": "intelliGit.branch.search",
        "title": "Search Branches",
        "icon": "$(search)"
      },
      {
        "command": "intelliGit.stash.create",
        "title": "Create Stash"
      },
      {
        "command": "intelliGit.stash.apply",
        "title": "Apply Stash"
      },
      {
        "command": "intelliGit.stash.pop",
        "title": "Pop Stash"
      },
      {
        "command": "intelliGit.stash.drop",
        "title": "Drop Stash"
      },
      {
        "command": "intelliGit.stash.rename",
        "title": "Rename Stash"
      },
      {
        "command": "intelliGit.stash.previewPatch",
        "title": "Preview Stash Patch"
      },
      {
        "command": "intelliGit.graph.openDetails",
        "title": "Open Commit Details"
      },
      {
        "command": "intelliGit.graph.openFileDiff",
        "title": "Open Commit File Diff"
      },
      {
        "command": "intelliGit.graph.checkoutCommit",
        "title": "Checkout Commit"
      },
      {
        "command": "intelliGit.graph.createBranchHere",
        "title": "Create Branch At Commit"
      },
      {
        "command": "intelliGit.graph.createTagHere",
        "title": "Create Tag At Commit"
      },
      {
        "command": "intelliGit.graph.cherryPick",
        "title": "Cherry-pick Commit"
      },
      {
        "command": "intelliGit.graph.cherryPickRange",
        "title": "Cherry-pick Commit Range"
      },
      {
        "command": "intelliGit.graph.revert",
        "title": "Revert Commit"
      },
      {
        "command": "intelliGit.graph.rebaseInteractiveFromHere",
        "title": "Interactive Rebase From Commit"
      },
      {
        "command": "intelliGit.graph.compareWithCurrent",
        "title": "Compare Commit With Current"
      },
      {
        "command": "intelliGit.graph.createPatch",
        "title": "Create Patch From Commit"
      },
      {
        "command": "intelliGit.graph.showRepositoryAtRevision",
        "title": "Show Repository At Revision"
      },
      {
        "command": "intelliGit.graph.openRepositoryFileAtRevision",
        "title": "Open File At Revision"
      },
      {
        "command": "intelliGit.graph.goToParentCommit",
        "title": "Go To Parent Commit"
      },
      {
        "command": "intelliGit.graph.filter",
        "title": "Filter Graph",
        "icon": "$(filter)"
      },
      {
        "command": "intelliGit.graph.clearFilter",
        "title": "Clear Graph Filters",
        "icon": "$(filter-filled)"
      },
      {
        "command": "intelliGit.diff.open",
        "title": "Open Diff"
      },
      {
        "command": "intelliGit.compare.open",
        "title": "Compare Branches"
      },
      {
        "command": "intelliGit.merge.openConflict",
        "title": "Open Conflict In Merge Editor"
      },
      {
        "command": "intelliGit.merge.next",
        "title": "Next Conflict"
      },
      {
        "command": "intelliGit.merge.previous",
        "title": "Previous Conflict"
      },
      {
        "command": "intelliGit.merge.finalize",
        "title": "Finalize Merge Resolution"
      },
      {
        "command": "intelliGit.conflict.acceptOurs",
        "title": "Accept Yours (Ours)",
        "category": "IntelliGit"
      },
      {
        "command": "intelliGit.conflict.acceptTheirs",
        "title": "Accept Theirs",
        "category": "IntelliGit"
      },
      {
        "command": "intelliGit.conflict.acceptBoth",
        "title": "Accept Both (Open Merge Editor)",
        "category": "IntelliGit"
      },
      {
        "command": "intelliGit.operation.abort",
        "title": "Abort Merge/Rebase/Cherry-Pick",
        "category": "IntelliGit"
      },
      {
        "command": "intelliGit.operation.continue",
        "title": "Continue Merge/Rebase/Cherry-Pick",
        "category": "IntelliGit"
      },
      {
        "command": "intelliGit.operation.skip",
        "title": "Skip Commit (Rebase/Cherry-Pick)",
        "category": "IntelliGit"
      },
      {
        "command": "intelliGit.git.pushWithPreview",
        "title": "Push (Preview)"
      },
      {
        "command": "intelliGit.git.pullWithPreview",
        "title": "Pull (Preview)"
      },
      {
        "command": "intelliGit.git.fetchPrune",
        "title": "Fetch --prune"
      },
      {
        "command": "intelliGit.stage.patch",
        "title": "Stage Selected Hunks"
      },
      {
        "command": "intelliGit.stage.file",
        "title": "Stage File"
      },
      {
        "command": "intelliGit.scm.shelveResource",
        "title": "Shelve Changes (IntelliGit)"
      },
      {
        "command": "intelliGit.unstage.file",
        "title": "Unstage File"
      },
      {
        "command": "intelliGit.commit.amend",
        "title": "Amend Last Commit"
      },
      {
        "command": "intelliGit.scm.commitTemplate",
        "title": "Insert Commit Template (SCM)"
      },
      {
        "command": "intelliGit.scm.generateCommitMessage",
        "title": "Generate Commit Message (SCM)"
      },
      {
        "command": "intelliGit.scm.amendFromInput",
        "title": "Amend Last Commit (SCM Input)"
      },
      {
        "command": "intelliGit.fileHistory.open",
        "title": "Open File History"
      },
      {
        "command": "intelliGit.fileBlame.open",
        "title": "Open File Blame"
      },
      {
        "command": "intelliGit.stash.unshelve",
        "title": "Unshelve Stash"
      },
      {
        "command": "intelliGit.commit.revertSelectedChanges",
        "title": "Revert Selected Changes"
      },
      {
        "command": "intelliGit.commit.cherryPickSelectedChanges",
        "title": "Cherry-pick Selected Changes"
      }
    ],
    "keybindings": [
      {
        "command": "workbench.action.closeActiveEditor",
        "key": "escape",
        "when": "textCompareEditorVisible && editorTextFocus && !findWidgetVisible && !suggestWidgetVisible"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "intelliGit.branch.actionHub",
          "when": "scmProvider == git",
          "group": "2_main@4.9"
        },
        {
          "command": "intelliGit.scm.commitTemplate",
          "when": "scmProvider == git",
          "group": "3_intelliGitCommit@1"
        },
        {
          "command": "intelliGit.scm.generateCommitMessage",
          "when": "scmProvider == git",
          "group": "3_intelliGitCommit@2"
        },
        {
          "command": "intelliGit.scm.amendFromInput",
          "when": "scmProvider == git",
          "group": "3_intelliGitCommit@3"
        }
      ],
      "git.branch": [
        {
          "command": "intelliGit.branch.actionHub",
          "when": "config.git.enabled && !git.missing && gitOpenRepositoryCount != 0",
          "group": "3_modify@0"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "intelliGit.scm.shelveResource",
          "when": "scmProvider == git && resourceScheme == file && scmResourceGroup != index",
          "group": "2_intelliGit@1"
        }
      ],
      "view/title": [
        {
          "command": "intelliGit.refresh",
          "when": "view == intelliGit.branches || view == intelliGit.stashes || view == intelliGit.graph",
          "group": "navigation"
        },
        {
          "command": "intelliGit.quickActions",
          "when": "view == intelliGit.branches || view == intelliGit.stashes || view == intelliGit.graph",
          "group": "navigation@1"
        },
        {
          "command": "intelliGit.branch.search",
          "when": "view == intelliGit.branches",
          "group": "navigation@2"
        },
        {
          "command": "intelliGit.graph.filter",
          "when": "view == intelliGit.graph",
          "group": "navigation@2"
        },
        {
          "command": "intelliGit.graph.clearFilter",
          "when": "view == intelliGit.graph && intelliGit.graphFilterActive",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "intelliGit.branch.checkout",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "inline"
        },
        {
          "command": "intelliGit.branch.compareWithCurrent",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation"
        },
        {
          "command": "intelliGit.branch.rename",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@1"
        },
        {
          "command": "intelliGit.branch.delete",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@2"
        },
        {
          "command": "intelliGit.branch.track",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@3"
        },
        {
          "command": "intelliGit.branch.untrack",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@4"
        },
        {
          "command": "intelliGit.branch.mergeIntoCurrent",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@5"
        },
        {
          "command": "intelliGit.branch.rebaseOnto",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@6"
        },
        {
          "command": "intelliGit.stash.apply",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "inline"
        },
        {
          "command": "intelliGit.stash.pop",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "navigation"
        },
        {
          "command": "intelliGit.stash.rename",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "navigation@1"
        },
        {
          "command": "intelliGit.stash.drop",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "navigation@2"
        },
        {
          "command": "intelliGit.stash.previewPatch",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "navigation"
        },
        {
          "command": "intelliGit.stash.unshelve",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "navigation@3"
        },
        {
          "command": "intelliGit.graph.openDetails",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "inline"
        },
        {
          "command": "intelliGit.graph.openFileDiff",
          "when": "view == intelliGit.graph && viewItem == graphCommitFile",
          "group": "inline"
        },
        {
          "command": "intelliGit.graph.checkoutCommit",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "navigation"
        },
        {
          "command": "intelliGit.graph.createBranchHere",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "navigation@1"
        },
        {
          "command": "intelliGit.graph.cherryPick",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "navigation@2"
        },
        {
          "command": "intelliGit.graph.revert",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "navigation@3"
        },
        {
          "command": "intelliGit.graph.compareWithCurrent",
          "when": "view == intelliGit.graph && viewItem == graphCommit",
          "group": "navigation@4"
        },
        {
          "command": "intelliGit.graph.openFileDiff",
          "when": "view == intelliGit.commitView && viewItem == commitViewFile",
          "group": "inline"
        },
        {
          "command": "intelliGit.commit.revertSelectedChanges",
          "when": "view == intelliGit.commitView && viewItem == commitViewFile && intelliGit.commitViewCanRevertSelected",
          "group": "navigation@1"
        },
        {
          "command": "intelliGit.commit.cherryPickSelectedChanges",
          "when": "view == intelliGit.commitView && viewItem == commitViewFile && intelliGit.commitViewCanCherryPickSelected",
          "group": "navigation@2"
        },
        {
          "command": "intelliGit.graph.openRepositoryFileAtRevision",
          "when": "view == intelliGit.commitView && viewItem == revisionViewFile",
          "group": "inline"
        },
        {
          "command": "intelliGit.commit.revertSelectedChanges",
          "when": "view == intelliGit.graph && viewItem == graphCommitFile",
          "group": "navigation@5"
        },
        {
          "command": "intelliGit.commit.cherryPickSelectedChanges",
          "when": "view == intelliGit.graph && viewItem == graphCommitFile",
          "group": "navigation@6"
        }
      ],
      "explorer/context": [
        {
          "command": "intelliGit.fileHistory.open",
          "when": "explorerResourceIsFolder == false && resourceScheme == file",
          "group": "navigation@9"
        }
      ],
      "commandPalette": [
        {
          "command": "intelliGit.fileHistory.open",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "IntelliGit",
      "properties": {
        "intelliGit.gitPath": {
          "type": "string",
          "default": "git",
          "description": "Git executable path."
        },
        "intelliGit.commandTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 2000,
          "description": "Timeout for Git commands in milliseconds."
        },
        "intelliGit.maxGraphCommits": {
          "type": "number",
          "default": 200,
          "minimum": 20,
          "description": "Maximum commits shown in Git Graph view."
        },
        "intelliGit.recentBranchesCount": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Number of branches shown in the Recent group."
        },
        "intelliGit.gutterMarkers.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inline gutter markers for lines added, modified, or deleted relative to HEAD."
        },
        "intelliGit.commitMessageTemplates": {
          "type": "array",
          "default": [
            {
              "label": "feat",
              "template": "feat({scope}): {cursor}"
            },
            {
              "label": "fix",
              "template": "fix({scope}): {cursor}"
            },
            {
              "label": "chore",
              "template": "chore: {cursor}"
            },
            {
              "label": "ticket",
              "template": "[{ticket}] {cursor}"
            }
          ],
          "description": "Reusable commit message templates. Each item is {label, template}. Placeholders: {branch}, {ticket}, {scope}, {cursor}.",
          "items": {
            "type": "object",
            "required": [
              "label",
              "template"
            ],
            "properties": {
              "label": {
                "type": "string",
                "description": "Display label in the template menu."
              },
              "template": {
                "type": "string",
                "description": "Template text. Supports {branch}, {ticket}, {scope}, {cursor}."
              }
            }
          }
        },
        "intelliGit.commitMessageTicketPattern": {
          "type": "string",
          "default": "[A-Z]+-\\d+",
          "description": "Regular expression used to extract a ticket id from the current branch name for the {ticket} placeholder."
        },
        "intelliGit.aiGenerateTimeoutMs": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "Timeout in milliseconds for AI commit message generation. Generation is cancelled if it exceeds this limit."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3"
  }
}