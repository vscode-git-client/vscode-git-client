    "keybindings": [
      {
        "command": "workbench.action.closeActiveEditor",
        "key": "escape",
        "when": "textCompareEditorVisible && editorTextFocus && !findWidgetVisible && !suggestWidgetVisible"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "intelliGit.branch.actionHub",
          "when": "scmProvider == git",
          "group": "2_main@4.9"
        },
        {
          "command": "intelliGit.scm.commitTemplate",
          "when": "scmProvider == git",
          "group": "3_intelliGitCommit@1"
        },
        {
          "command": "intelliGit.scm.generateCommitMessage",
          "when": "scmProvider == git",
          "group": "3_intelliGitCommit@2"
        },
        {
          "command": "intelliGit.scm.amendFromInput",
          "when": "scmProvider == git",
          "group": "3_intelliGitCommit@3"
        }
      ],
      "git.branch": [
        {
          "command": "intelliGit.branch.actionHub",
          "when": "config.git.enabled && !git.missing && gitOpenRepositoryCount != 0",
          "group": "3_modify@0"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "intelliGit.scm.shelveResource",
          "when": "scmProvider == git && resourceScheme == file && scmResourceGroup != index",
          "group": "2_intelliGit@1"
        }
      ],
      "view/title": [
        {
          "command": "intelliGit.worktree.addFromBranch",
          "when": "view == intelliGit.worktrees",
          "group": "navigation@1"
        },
        {
          "command": "intelliGit.worktree.prune",
          "when": "view == intelliGit.worktrees",
          "group": "navigation@2"
        },
        {
          "command": "intelliGit.submodule.initAll",
          "when": "view == intelliGit.submodules",
          "group": "navigation@1"
        },
        {
          "command": "intelliGit.submodule.updateAll",
          "when": "view == intelliGit.submodules && intelliGit.hasSubmodules",
          "group": "navigation@2"
        },
        {
          "command": "intelliGit.branch.search",
          "when": "view == intelliGit.branches",
          "group": "navigation@8"
        },
        {
          "command": "intelliGit.branch.create",
          "when": "view == intelliGit.branches",
          "group": "navigation@8.1"
        },
        {
          "command": "intelliGit.graph.filter",
          "when": "view == intelliGit.graph",
          "group": "navigation@8"
        },
        {
          "command": "intelliGit.graph.clearFilter",
          "when": "view == intelliGit.graph && intelliGit.graphFilterActive",
          "group": "navigation@8.1"
        },
        {
          "command": "intelliGit.refresh",
          "when": "view == intelliGit.branches || view == intelliGit.stashes || view == intelliGit.graph",
          "group": "refresh@1"
        },
        {
          "command": "intelliGit.worktree.refresh",
          "when": "view == intelliGit.worktrees",
          "group": "refresh@1"
        },
        {
          "command": "intelliGit.submodule.refresh",
          "when": "view == intelliGit.submodules",
          "group": "refresh@1"
        }
      ],
      "view/item/context": [
        {
          "command": "intelliGit.branch.checkout",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation"
        },
        {
          "command": "intelliGit.branch.compareWithCurrent",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation"
        },
        {
          "command": "intelliGit.branch.rename",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@1"
        },
        {
          "command": "intelliGit.branch.delete",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@2"
        },
        {
          "command": "intelliGit.branch.track",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@3"
        },
        {
          "command": "intelliGit.branch.untrack",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@4"
        },
        {
          "command": "intelliGit.branch.mergeIntoCurrent",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@5"
        },
        {
          "command": "intelliGit.branch.rebaseOnto",
          "when": "view == intelliGit.branches && viewItem == branchRef",
          "group": "navigation@6"
        },
        {
          "command": "intelliGit.tag.checkout",
          "when": "view == intelliGit.branches && viewItem == tagRef",
          "group": "navigation"
        },
        {
          "command": "intelliGit.tag.checkoutNewBranch",
          "when": "view == intelliGit.branches && viewItem == tagRef",
          "group": "navigation"
        },
        {
          "command": "intelliGit.tag.copyRevisionNumber",
          "when": "view == intelliGit.branches && viewItem == tagRef",
          "group": "navigation@1"
        },
        {
          "command": "intelliGit.tag.showRepositoryAtRevision",
          "when": "view == intelliGit.branches && viewItem == tagRef",
          "group": "navigation@2"
        },
        {
          "command": "intelliGit.tag.compareWithCurrent",
          "when": "view == intelliGit.branches && viewItem == tagRef",
          "group": "navigation@3"
        },
        {
          "command": "intelliGit.tag.createPatch",
          "when": "view == intelliGit.branches && viewItem == tagRef",
          "group": "navigation@4"
        },
        {
          "command": "intelliGit.tag.createCurrent",
          "when": "view == intelliGit.branches && viewItem == tagSection",
          "group": "inline@1"
        },
        {
          "command": "intelliGit.remote.changeUrl",
          "when": "view == intelliGit.branches && viewItem == branchRemoteGroup && intelliGit.remoteHasUrl",
          "group": "navigation"
        },
        {
          "command": "intelliGit.remote.setUrlMissing",
          "when": "view == intelliGit.branches && viewItem == branchRemoteGroup && !intelliGit.remoteHasUrl",
          "group": "navigation"
        },
        {
          "command": "intelliGit.remote.add",
          "when": "view == intelliGit.branches && viewItem == branchSectionRemote",
          "group": "navigation"
        },
        {
          "command": "intelliGit.refresh",
          "when": "view == intelliGit.branches && !viewItem",
          "group": "navigation"
        },
        {
          "command": "intelliGit.refresh",
          "when": "view == intelliGit.stashes && !viewItem",
          "group": "navigation"
        },
        {
          "command": "intelliGit.refresh",
          "when": "view == intelliGit.graph && !viewItem",
          "group": "navigation"
        },
        {
          "command": "intelliGit.worktree.refresh",
          "when": "view == intelliGit.worktrees && !viewItem",
          "group": "navigation"
        },
        {
          "command": "intelliGit.submodule.refresh",
          "when": "view == intelliGit.submodules && !viewItem",
          "group": "navigation"
        },
        {
          "command": "intelliGit.stash.apply",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "inline"
        },
        {
          "command": "intelliGit.stash.pop",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "navigation"
        },
        {
          "command": "intelliGit.stash.rename",
          "when": "view == intelliGit.stashes && viewItem == stashEntry",
          "group": "navigation@1"
        },
        {
