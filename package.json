    "configuration": {
      "title": "VS Code Git Client",
      "properties": {
        "vscodeGitClient.gitPath": {
          "type": "string",
          "default": "git",
          "description": "Git executable path."
        },
        "vscodeGitClient.commandTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 2000,
          "description": "Timeout for Git commands in milliseconds."
        },
        "vscodeGitClient.maxGraphCommits": {
          "type": "number",
          "default": 200,
          "minimum": 20,
          "description": "Maximum commits shown in Git Graph view."
        },
        "vscodeGitClient.commitListVirtualizationThreshold": {
          "type": "number",
          "default": 200,
          "minimum": 0,
          "description": "Enable DOM-row virtualization in commit list webviews (Directory Timeline, branch/tag history, Filter Graph) when the visible row count exceeds this threshold. Set to 0 to disable virtualization entirely."
        },
        "vscodeGitClient.recentBranchesCount": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Number of branches shown in the Recent group."
        },
        "vscodeGitClient.gutterMarkers.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inline gutter markers for lines added, modified, or deleted relative to HEAD."
        },
        "vscodeGitClient.gutterMarkers.maxFileSizeKb": {
          "type": "number",
          "default": 512,
          "minimum": 1,
          "description": "Skip inline gutter marker computation for files larger than this size in KB."
        },
        "vscodeGitClient.gutterMarkers.maxLineCount": {
          "type": "number",
          "default": 10000,
          "minimum": 1,
          "description": "Skip inline gutter marker computation for files with more lines than this value."
        },
        "vscodeGitClient.performance.logGitCommands": {
          "type": "boolean",
          "default": false,
          "description": "Log Git commands that take 500ms or longer to the VS Code Git Client output channel."
        },
        "vscodeGitClient.performance.refreshDebounceMs": {
          "type": "number",
          "default": 250,
          "minimum": 0,
          "description": "Debounce delay in milliseconds for VS Code Git repository-state auto-refresh events."
        },
        "vscodeGitClient.performance.saveRefreshDebounceMs": {
          "type": "number",
          "default": 150,
          "minimum": 0,
          "description": "Debounce delay in milliseconds for save-triggered working-tree refresh events."
        },
        "vscodeGitClient.compare.exportFormat": {
          "type": "string",
          "enum": [
            "csv",
            "excel"
          ],
          "default": "csv",
          "description": "Default export format for Compare Branches webview. CSV exports two branch-specific files; Excel exports one .xlsx with two sheets."
        },
        "vscodeGitClient.compareWithRevision.defaultDirection": {
          "type": "string",
          "enum": [
            "forward",
            "reverse"
          ],
          "default": "forward",
          "description": "Default diff direction for Compare with Revision. forward opens working tree on the left and selected revision on the right; reverse opens selected revision on the left and working tree on the right."
        },
        "vscodeGitClient.commitMessageTemplates": {
          "type": "array",
          "default": [
            {
              "label": "feat",
              "template": "feat({scope}): {cursor}"
            },
            {
              "label": "fix",
              "template": "fix({scope}): {cursor}"
            },
            {
              "label": "chore",
              "template": "chore: {cursor}"
            },
            {
              "label": "ticket",
              "template": "[{ticket}] {cursor}"
            }
          ],
          "description": "Reusable commit message templates. Each item is {label, template}. Placeholders: {branch}, {ticket}, {scope}, {cursor}.",
          "items": {
            "type": "object",
            "required": [
              "label",
              "template"
            ],
            "properties": {
              "label": {
                "type": "string",
                "description": "Display label in the template menu."
              },
              "template": {
                "type": "string",
                "description": "Template text. Supports {branch}, {ticket}, {scope}, {cursor}."
              }
            }
          }
        },
        "vscodeGitClient.commitMessageTicketPattern": {
          "type": "string",
          "default": "[A-Z]+-\\d+",
          "description": "Regular expression used to extract a ticket id from the current branch name for the {ticket} placeholder."
        },
        "vscodeGitClient.aiGenerateTimeoutMs": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "Timeout in milliseconds for AI commit message generation. Generation is cancelled if it exceeds this limit."
        }
      }
    }
  },
