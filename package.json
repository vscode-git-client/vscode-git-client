    "keybindings": [
      {
        "command": "workbench.action.closeActiveEditor",
        "key": "escape",
        "when": "textCompareEditorVisible && editorTextFocus && !findWidgetVisible && !suggestWidgetVisible"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "vscodeGitClient.branch.actionHub",
          "when": "scmProvider == git",
          "group": "2_main@4.9"
        },
        {
          "command": "vscodeGitClient.scm.commitTemplate",
          "when": "scmProvider == git",
          "group": "3_vscodeGitClientCommit@1"
        },
        {
          "command": "vscodeGitClient.scm.generateCommitMessage",
          "when": "scmProvider == git",
          "group": "3_vscodeGitClientCommit@2"
        },
        {
          "command": "vscodeGitClient.scm.amendFromInput",
          "when": "scmProvider == git",
          "group": "3_vscodeGitClientCommit@3"
        }
      ],
      "git.branch": [
        {
          "command": "vscodeGitClient.branch.actionHub",
          "when": "config.git.enabled && !git.missing && gitOpenRepositoryCount != 0",
          "group": "3_modify@0"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "vscodeGitClient.scm.shelveResource",
          "when": "scmProvider == git && resourceScheme == file && scmResourceGroup != index",
          "group": "2_vscodeGitClient@1"
        }
      ],
      "view/title": [
        {
          "command": "vscodeGitClient.commitView.close",
          "when": "view == vscodeGitClient.commitView",
          "group": "navigation@9"
        },
        {
          "command": "vscodeGitClient.worktree.addFromBranch",
          "when": "view == vscodeGitClient.worktrees",
          "group": "navigation@1"
        },
        {
          "command": "vscodeGitClient.worktree.prune",
          "when": "view == vscodeGitClient.worktrees",
          "group": "navigation@2"
        },
        {
          "command": "vscodeGitClient.submodule.initAll",
          "when": "view == vscodeGitClient.submodules",
          "group": "navigation@1"
        },
        {
          "command": "vscodeGitClient.submodule.updateAll",
          "when": "view == vscodeGitClient.submodules && vscodeGitClient.hasSubmodules",
          "group": "navigation@2"
        },
        {
          "command": "vscodeGitClient.branch.search",
          "when": "view == vscodeGitClient.branches",
          "group": "navigation@8"
        },
        {
          "command": "vscodeGitClient.branch.create",
          "when": "view == vscodeGitClient.branches",
          "group": "navigation@8.1"
        },
        {
          "command": "vscodeGitClient.graph.filter",
          "when": "view == vscodeGitClient.graph",
          "group": "navigation@8"
        },
        {
          "command": "vscodeGitClient.graph.clearFilter",
          "when": "view == vscodeGitClient.graph && vscodeGitClient.graphFilterActive",
          "group": "navigation@8.1"
        },
        {
          "command": "vscodeGitClient.refresh",
          "when": "view == vscodeGitClient.branches || view == vscodeGitClient.stashes || view == vscodeGitClient.graph",
          "group": "refresh@1"
        },
        {
          "command": "vscodeGitClient.worktree.refresh",
          "when": "view == vscodeGitClient.worktrees",
          "group": "refresh@1"
        },
        {
          "command": "vscodeGitClient.submodule.refresh",
          "when": "view == vscodeGitClient.submodules",
          "group": "refresh@1"
        }
      ],
      "webview/context": [
        {
          "command": "vscodeGitClient.branch.search.refresh",
          "when": "webviewId == 'vscodeGitClient.branchSearch'",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "vscodeGitClient.branch.checkout",
          "when": "view == vscodeGitClient.branches && (viewItem == branchRefLocal || viewItem == branchRefRemote)",
          "group": "navigation"
        },
        {
          "command": "vscodeGitClient.branch.compareWithCurrent",
          "when": "view == vscodeGitClient.branches && (viewItem == branchRefLocal || viewItem == branchRefRemote)",
          "group": "navigation"
        },
        {
          "command": "vscodeGitClient.branch.rename",
          "when": "view == vscodeGitClient.branches && viewItem == branchRefLocal",
          "group": "navigation@1"
        },
        {
          "command": "vscodeGitClient.branch.delete",
          "when": "view == vscodeGitClient.branches && viewItem == branchRefLocal",
          "group": "navigation@2"
        },
        {
          "command": "vscodeGitClient.branch.track",
          "when": "view == vscodeGitClient.branches && viewItem == branchRefLocal",
          "group": "navigation@3"
        },
        {
          "command": "vscodeGitClient.branch.untrack",
          "when": "view == vscodeGitClient.branches && viewItem == branchRefLocal",
          "group": "navigation@4"
        },
        {
          "command": "vscodeGitClient.branch.mergeIntoCurrent",
          "when": "view == vscodeGitClient.branches && (viewItem == branchRefLocal || viewItem == branchRefRemote)",
          "group": "navigation@5"
        },
        {
          "command": "vscodeGitClient.branch.rebaseOnto",
          "when": "view == vscodeGitClient.branches && (viewItem == branchRefLocal || viewItem == branchRefRemote)",
          "group": "navigation@6"
        },
        {
