          "group": "inline"
        },
        {
          "command": "intelliGit.commit.revertSelectedChanges",
          "when": "view == intelliGit.graph && viewItem == graphCommitFile",
          "group": "navigation@5"
        },
        {
          "command": "intelliGit.commit.cherryPickSelectedChanges",
          "when": "view == intelliGit.graph && viewItem == graphCommitFile",
          "group": "navigation@6"
        },
        {
          "command": "intelliGit.worktree.openInNewWindow",
          "when": "view == intelliGit.worktrees && viewItem =~ /worktreeEntry/",
          "group": "inline"
        },
        {
          "command": "intelliGit.worktree.open",
          "when": "view == intelliGit.worktrees && viewItem =~ /worktreeEntry/",
          "group": "navigation@1"
        },
        {
          "command": "intelliGit.worktree.openInNewWindow",
          "when": "view == intelliGit.worktrees && viewItem =~ /worktreeEntry/",
          "group": "navigation@2"
        },
        {
          "command": "intelliGit.worktree.revealInFinder",
          "when": "view == intelliGit.worktrees && viewItem =~ /worktreeEntry/",
          "group": "navigation@3"
        },
        {
          "command": "intelliGit.worktree.openTerminal",
          "when": "view == intelliGit.worktrees && viewItem =~ /worktreeEntry/",
          "group": "navigation@4"
        },
        {
          "command": "intelliGit.worktree.lock",
          "when": "view == intelliGit.worktrees && viewItem =~ /worktreeEntry/ && !(viewItem =~ /worktreeLocked/) && !(viewItem =~ /worktreeCurrent/)",
          "group": "manage@1"
        },
        {
          "command": "intelliGit.worktree.unlock",
          "when": "view == intelliGit.worktrees && viewItem =~ /worktreeLocked/",
          "group": "manage@2"
        },
        {
          "command": "intelliGit.worktree.remove",
          "when": "view == intelliGit.worktrees && viewItem =~ /worktreeEntry/ && !(viewItem =~ /worktreeCurrent/) && !(viewItem =~ /worktreeLocked/)",
          "group": "danger@1"
        },
        {
          "command": "intelliGit.worktree.removeForce",
          "when": "view == intelliGit.worktrees && viewItem =~ /worktreeEntry/ && !(viewItem =~ /worktreeCurrent/)",
          "group": "danger@2"
        },
        {
          "command": "intelliGit.submodule.openInNewWindow",
          "when": "view == intelliGit.submodules && viewItem =~ /submoduleEntry/",
