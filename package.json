{
  "name": "vscode-git-client",
  "displayName": "IntelliGit Client",
  "description": "A powerful Git client for VS Code with branch tree, stashes, graph, submodules, worktrees, merge/diff/compare workflows, inspired by IntelliJ Git integration.",
  "version": "0.21.0",
  "publisher": "thanhtunguet",
  "icon": "media/intelligit.png",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/thanhtunguet/IntelliGit"
  },
  "activationEvents": [
    "onView:intelliGit.stashes",
    "onView:intelliGit.branches",
    "onCommand:intelliGit.quickActions",
    "onCommand:intelliGit.branch.actionHub",
    "onCommand:intelliGit.compareWithRevision",
    "onCommand:intelliGit.fileBlame.open",
    "onCommand:intelliGit.scm.shelveResource",
    "onCommand:intelliGit.scm.commitTemplate",
    "onCommand:intelliGit.scm.generateCommitMessage",
    "onCommand:intelliGit.scm.amendFromInput"
  ],
  "scripts": {
    "clean": "node scripts/clean-dist.js",
    "compile": "npm run clean && tsc -p . && node scripts/copy-templates.js",
    "check-types": "tsc -p . --noEmit",
    "bundle": "npm run clean && esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --outfile=dist/extension.js && node scripts/copy-templates.js",
    "copy-templates": "node scripts/copy-templates.js",
    "vscode:prepublish": "npm run check-types && npm run bundle",
    "watch": "tsc -watch -p .",
    "lint": "eslint src --ext .ts",
    "test": "npm run compile && node --require ./scripts/register-vscode-mock.js --test dist/test/*.test.js"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "intelliGit",
          "title": "IntelliGit",
          "icon": "media/intelligit.svg",
          "order": 999
        }
      ]
    },
    "views": {
      "intelliGit": [
        {
          "id": "intelliGit.branches",
          "name": "Branches",
          "contextualTitle": "Browse and manage local and remote branches",
          "visibility": "visible",
          "icon": "media/icon-branches.svg"
        },
        {
          "id": "intelliGit.commitView",
          "name": "Commit Details",
          "contextualTitle": "Inspect changed files and diffs in a selected commit",
          "when": "intelliGit.commitViewVisible",
          "icon": "media/icon-commit-view.svg"
        },
        {
          "id": "intelliGit.graph",
          "name": "Git Graph",
          "contextualTitle": "Visual commit history and branch graph",
          "visibility": "visible",
          "icon": "media/icon-graph.svg"
        },
        {
          "id": "intelliGit.worktrees",
          "name": "Worktrees",
          "contextualTitle": "Manage git worktrees for parallel development",
          "visibility": "visible",
          "icon": "media/icon-worktrees.svg"
        },
        {
          "id": "intelliGit.submodules",
          "name": "Submodules",
          "contextualTitle": "Manage nested git submodule repositories",
          "visibility": "visible",
          "icon": "media/icon-submodules.svg"
        }
      ],
      "scm": [
        {
          "id": "intelliGit.stashes",
          "name": "Stashes",
          "contextualTitle": "Stashed changes",
          "visibility": "collapsed",
          "icon": "media/icon-stashes.svg",
          "initialSize": 0,
          "type": "tree",
          "accessibilityHelpContent": "IntelliGit: View stashed changes"
        }
      ]
    },
    "commands": [
