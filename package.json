{
  "name": "vscode-git-client",
  "displayName": "VS Code Git Client",
  "description": "A powerful Git client for VS Code with branch tree, stashes, graph, submodules, worktrees, merge/diff/compare workflows.",
  "version": "1.13.0",
  "publisher": "thanhtunguet",
  "icon": "media/vscodegitclient.png",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vscode-git-client/vscode-git-client",
    "issues": "https://github.com/vscode-git-client/vscode-git-client/issues"
  },
  "activationEvents": [
    "onView:vscodeGitClient.stashes",
    "onView:vscodeGitClient.branches",
    "onCommand:vscodeGitClient.quickActions",
    "onCommand:vscodeGitClient.branch.actionHub",
    "onCommand:vscodeGitClient.compareWithRevision",
    "onCommand:vscodeGitClient.compareWithRevision.swapDirection",
    "onCommand:vscodeGitClient.directoryTimeline.open",
    "onCommand:vscodeGitClient.fileBlame.open",
    "onCommand:vscodeGitClient.scm.shelveResource",
    "onCommand:vscodeGitClient.scm.commitTemplate",
    "onCommand:vscodeGitClient.scm.generateCommitMessage",
    "onCommand:vscodeGitClient.scm.amendFromInput"
  ],
  "scripts": {
    "clean": "node scripts/clean-dist.js",
    "compile": "pnpm run clean && tsc -p . && node scripts/copy-templates.js",
    "check-types": "tsc -p . --noEmit",
    "bundle": "pnpm run clean && esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --outfile=dist/extension.js && node scripts/copy-templates.js",
    "copy-templates": "node scripts/copy-templates.js",
    "vscode:prepublish": "pnpm run check-types && pnpm run bundle",
    "watch": "tsc -watch -p .",
    "lint": "eslint src --ext .ts",
    "test": "pnpm run compile && node --require ./scripts/register-vscode-mock.js --test dist/test/*.test.js",
    "docs:dev": "pnpm --dir website run dev",
    "docs:build": "pnpm --dir website run build",
    "docs:preview": "pnpm --dir website run preview",
    "postdocs:build": "cp website/logo.* website/.vitepress/dist/"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscodeGitClient",
          "title": "VS Code Git Client",
          "icon": "media/vscodegitclient.svg",
          "order": 999
        }
      ]
    },
    "views": {
      "vscodeGitClient": [
        {
          "id": "vscodeGitClient.branches",
          "name": "Branches",
          "contextualTitle": "Browse and manage local and remote branches",
          "visibility": "visible",
          "icon": "media/icon-branches.svg"
        },
        {
          "id": "vscodeGitClient.commitView",
          "name": "Commit Details",
          "contextualTitle": "Inspect changed files and diffs in a selected commit",
          "when": "vscodeGitClient.commitViewVisible",
          "icon": "media/icon-commit-view.svg"
        },
        {
          "id": "vscodeGitClient.graph",
          "name": "Git Graph",
          "contextualTitle": "Visual commit history and branch graph",
          "visibility": "visible",
          "icon": "media/icon-graph.svg"
        },
        {
          "id": "vscodeGitClient.worktrees",
          "name": "Worktrees",
          "contextualTitle": "Manage git worktrees for parallel development",
          "visibility": "visible",
          "icon": "media/icon-worktrees.svg"
        },
        {
          "id": "vscodeGitClient.submodules",
          "name": "Submodules",
          "contextualTitle": "Manage nested git submodule repositories",
          "visibility": "visible",
          "icon": "media/icon-submodules.svg"
        }
      ],
      "scm": [
        {
          "id": "vscodeGitClient.stashes",
          "name": "Stashes",
          "contextualTitle": "Stashed changes",
          "visibility": "collapsed",
          "icon": "media/icon-stashes.svg",
          "initialSize": 0,
          "type": "tree",
          "accessibilityHelpContent": "VS Code Git Client: View stashed changes"
        }
      ]
    },
