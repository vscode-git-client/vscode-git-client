      "explorer/context": [
        {
          "command": "intelliGit.compareWithRevision",
          "when": "resourceScheme == file",
          "group": "z_intelliGit@1"
        }
      ],
      "commandPalette": [
        {
          "command": "intelliGit.compareWithRevision",
          "when": "false"
        },
        {
          "command": "intelliGit.workingTreeCompare.openFileDiff",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "IntelliGit",
      "properties": {
        "intelliGit.gitPath": {
          "type": "string",
          "default": "git",
          "description": "Git executable path."
        },
        "intelliGit.commandTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 2000,
          "description": "Timeout for Git commands in milliseconds."
        },
        "intelliGit.maxGraphCommits": {
          "type": "number",
          "default": 200,
          "minimum": 20,
          "description": "Maximum commits shown in Git Graph view."
        },
        "intelliGit.recentBranchesCount": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Number of branches shown in the Recent group."
        },
        "intelliGit.gutterMarkers.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inline gutter markers for lines added, modified, or deleted relative to HEAD."
        },
        "intelliGit.gutterMarkers.maxFileSizeKb": {
          "type": "number",
          "default": 512,
          "minimum": 1,
          "description": "Skip inline gutter marker computation for files larger than this size in KB."
        },
        "intelliGit.gutterMarkers.maxLineCount": {
          "type": "number",
          "default": 10000,
          "minimum": 1,
          "description": "Skip inline gutter marker computation for files with more lines than this value."
        },
        "intelliGit.performance.logGitCommands": {
          "type": "boolean",
          "default": false,
          "description": "Log Git commands that take 500ms or longer to the IntelliGit output channel."
        },
        "intelliGit.performance.refreshDebounceMs": {
          "type": "number",
          "default": 250,
          "minimum": 0,
          "description": "Debounce delay in milliseconds for VS Code Git repository-state auto-refresh events."
        },
        "intelliGit.performance.saveRefreshDebounceMs": {
          "type": "number",
          "default": 150,
          "minimum": 0,
          "description": "Debounce delay in milliseconds for save-triggered working-tree refresh events."
        },
        "intelliGit.compare.exportFormat": {
          "type": "string",
          "enum": [
            "csv",
            "excel"
          ],
          "default": "csv",
          "description": "Default export format for Compare Branches webview. CSV exports two branch-specific files; Excel exports one .xlsx with two sheets."
        },
        "intelliGit.commitMessageTemplates": {
          "type": "array",
          "default": [
            {
              "label": "feat",
              "template": "feat({scope}): {cursor}"
            },
            {
              "label": "fix",
              "template": "fix({scope}): {cursor}"
            },
            {
              "label": "chore",
              "template": "chore: {cursor}"
            },
            {
              "label": "ticket",
              "template": "[{ticket}] {cursor}"
            }
          ],
          "description": "Reusable commit message templates. Each item is {label, template}. Placeholders: {branch}, {ticket}, {scope}, {cursor}.",
          "items": {
            "type": "object",
            "required": [
              "label",
              "template"
            ],
            "properties": {
              "label": {
                "type": "string",
                "description": "Display label in the template menu."
              },
              "template": {
                "type": "string",
                "description": "Template text. Supports {branch}, {ticket}, {scope}, {cursor}."
              }
            }
          }
        },
        "intelliGit.commitMessageTicketPattern": {
          "type": "string",
          "default": "[A-Z]+-\\d+",
          "description": "Regular expression used to extract a ticket id from the current branch name for the {ticket} placeholder."
        },
        "intelliGit.aiGenerateTimeoutMs": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "Timeout in milliseconds for AI commit message generation. Generation is cancelled if it exceeds this limit."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "handlebars": "^4.7.9",
    "typescript": "^6.0.3",
    "xlsx": "^0.18.5"
  }
